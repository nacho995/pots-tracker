@page "/login"
@inject AuthClient Auth
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>POTS</PageTitle>

<div class="shell shell--narrow flow stagger">
    <p class="eyebrow">@Lang.T("login.eyebrow")</p>

    @if (state == State.LinkSent)
    {
        <h1><span class="accent-rule"></span>@Lang.T("login.sent.title")</h1>

        <p class="lead">@Lang.T("login.sent.lead")</p>

        <hr class="divider divider--ornament" aria-hidden="true" />

        <p class="muted">
            @Lang.T("login.sent.checkSpam")
            <button type="button" class="btn--link" @onclick="Reset">@Lang.T("login.sent.again")</button>.
        </p>
    }
    else
    {
        <h1><span class="accent-rule"></span>@Lang.T("login.title")</h1>

        <p class="lead">@Lang.T("login.lead")</p>

        <EditForm Model="this" OnValidSubmit="HandleSubmitAsync">
            <div>
                <label for="email-input">@Lang.T("login.email")</label>
                <input id="email-input" type="email" inputmode="email" autocomplete="email"
                       placeholder="tu@correo.com" @bind="email" required disabled="@busy" />
            </div>

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>@(busy ? Lang.T("login.sending") : Lang.T("login.send"))</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        @if (errorMessage is not null)
        {
            <p class="error-text" role="alert">@errorMessage</p>
        }
    }
</div>

@code {
    private enum State { Idle, LinkSent }
    private State state = State.Idle;
    private string email = "";
    private bool busy = false;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (!string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/profile", replace: true);
        }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task HandleSubmitAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            await Auth.RequestMagicLinkAsync(email);
            state = State.LinkSent;
        }
        catch
        {
            errorMessage = Lang.T("login.error");
        }
        finally
        {
            busy = false;
        }
    }

    private void Reset()
    {
        state = State.Idle;
        email = "";
        errorMessage = null;
    }
}
