@page "/login"
@inject AuthClient Auth
@inject NavigationManager Nav

<PageTitle>Acceso — POTS</PageTitle>

<div class="shell shell--narrow flow stagger">
    <p class="eyebrow">Acceso · sin contraseña</p>

    @if (state == State.LinkSent)
    {
        <h1><span class="accent-rule"></span>Revisa<br />tu correo.</h1>

        <p class="lead">
            Si el email es válido, recibirás un enlace en breve.
            Tienes <strong>15 minutos</strong> para usarlo y solo funciona una vez.
        </p>

        <hr class="divider divider--ornament" aria-hidden="true" />

        <p class="muted">
            ¿No te llega? Mira la carpeta de spam, o
            <button type="button" class="btn--link" @onclick="Reset">prueba con otro email</button>.
        </p>
    }
    else
    {
        <h1><span class="accent-rule"></span>Buenos<br />días.</h1>

        <p class="lead">
            Introduce tu correo y te enviamos un enlace para entrar.
            Nada de contraseñas que recordar.
        </p>

        <EditForm Model="this" OnValidSubmit="HandleSubmitAsync">
            <div>
                <label for="email-input">Tu correo</label>
                <input id="email-input" type="email" inputmode="email" autocomplete="email"
                       placeholder="tu@correo.com" @bind="email" required disabled="@busy" />
            </div>

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>@(busy ? "Enviando..." : "Enviar enlace")</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        @if (errorMessage is not null)
        {
            <p class="error-text" role="alert">@errorMessage</p>
        }
    }
</div>

@code {
    private enum State { Idle, LinkSent }
    private State state = State.Idle;
    private string email = "";
    private bool busy = false;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/profile", replace: true);
        }
    }

    private async Task HandleSubmitAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            await Auth.RequestMagicLinkAsync(email);
            state = State.LinkSent;
        }
        catch
        {
            errorMessage = "No se ha podido enviar el enlace. Inténtalo de nuevo en unos minutos.";
        }
        finally
        {
            busy = false;
        }
    }

    private void Reset()
    {
        state = State.Idle;
        email = "";
        errorMessage = null;
    }
}
