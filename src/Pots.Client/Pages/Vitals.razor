@page "/log/vitals"
@inject AuthClient Auth
@inject VitalClient VitalClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("vitals.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("vitals.eyebrow")</p>

    @if (saved)
    {
        <h1><span class="accent-rule"></span>@Lang.T("vitals.saved.title")</h1>
        <p class="lead">@Lang.T("vitals.saved.lead")</p>
        <div class="action-row">
            <a href="/today" class="btn--primary" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5em;text-decoration:none;">
                <span>@Lang.T("common.backToToday")</span><span class="arrow" aria-hidden="true">→</span>
            </a>
            <button class="btn--ghost" @onclick="Reset">@Lang.T("vitals.saved.again")</button>
        </div>
    }
    else
    {
        <h1><span class="accent-rule"></span>@Lang.T("vitals.title")</h1>
        <p class="lead">@Lang.T("vitals.lead")</p>

        <EditForm Model="this" OnValidSubmit="SaveAsync" class="flow">

            <section class="card flow">
                <p class="card__label">@Lang.T("vitals.hr.label")</p>
                <label for="hr-rest">@Lang.T("vitals.hr.resting")</label>
                <input id="hr-rest" type="number" min="20" max="250" @bind="form.RestingHrBpm" />

                <label for="hr-2">@Lang.T("vitals.hr.standing2")</label>
                <input id="hr-2" type="number" min="20" max="250" @bind="form.StandingHrBpm2Min" />

                <label for="hr-5">@Lang.T("vitals.hr.standing5")</label>
                <input id="hr-5" type="number" min="20" max="250" @bind="form.StandingHrBpm5Min" />

                <label for="hr-10">@Lang.T("vitals.hr.standing10")</label>
                <input id="hr-10" type="number" min="20" max="250" @bind="form.StandingHrBpm10Min" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("vitals.bp.label")</p>

                <label>@Lang.T("vitals.bp.lying")</label>
                <div class="bp-row">
                    <input type="number" min="50" max="250" @bind="form.BpLyingSystolic" placeholder="120" aria-label="@Lang.T("vitals.bp.sysLying")" />
                    <span class="bp-row__sep" aria-hidden="true">/</span>
                    <input type="number" min="30" max="180" @bind="form.BpLyingDiastolic" placeholder="80" aria-label="@Lang.T("vitals.bp.diaLying")" />
                </div>

                <label>@Lang.T("vitals.bp.sitting")</label>
                <div class="bp-row">
                    <input type="number" min="50" max="250" @bind="form.BpSittingSystolic" placeholder="120" aria-label="@Lang.T("vitals.bp.sysSitting")" />
                    <span class="bp-row__sep" aria-hidden="true">/</span>
                    <input type="number" min="30" max="180" @bind="form.BpSittingDiastolic" placeholder="80" aria-label="@Lang.T("vitals.bp.diaSitting")" />
                </div>

                <label>@Lang.T("vitals.bp.standing")</label>
                <div class="bp-row">
                    <input type="number" min="50" max="250" @bind="form.BpStandingSystolic" placeholder="120" aria-label="@Lang.T("vitals.bp.sysStanding")" />
                    <span class="bp-row__sep" aria-hidden="true">/</span>
                    <input type="number" min="30" max="180" @bind="form.BpStandingDiastolic" placeholder="80" aria-label="@Lang.T("vitals.bp.diaStanding")" />
                </div>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("vitals.other.label")</p>

                <label for="spo2">@Lang.T("vitals.spo2")</label>
                <input id="spo2" type="number" min="50" max="100" @bind="form.Spo2Percent" />

                <label for="weight">@Lang.T("vitals.weight")</label>
                <input id="weight" type="number" step="0.1" @bind="form.WeightKg" />

                <label for="cycle">@Lang.T("vitals.cycle")</label>
                <input id="cycle" type="number" min="1" max="60" @bind="form.MenstrualCycleDay" />

                <label for="temp">@Lang.T("vitals.temp")</label>
                <input id="temp" type="number" step="0.1" @bind="form.AmbientTempC" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("vitals.sleep.label")</p>

                <label for="sleep-min">@Lang.T("vitals.sleep.duration")</label>
                <input id="sleep-min" type="number" min="0" max="1440" @bind="form.SleepDurationMinutes" />

                <SymptomScale Label="@Lang.T("vitals.sleep.quality")" @bind-Value="form.SleepQuality" />

                <label for="steps">@Lang.T("vitals.steps")</label>
                <input id="steps" type="number" min="0" @bind="form.Steps" />

                <label for="ex-min">@Lang.T("vitals.exMinutes")</label>
                <input id="ex-min" type="number" min="0" max="1440" @bind="form.ExerciseMinutes" />

                <label for="upright">@Lang.T("vitals.upright")</label>
                <input id="upright" type="number" min="0" max="1440" @bind="form.TimeUprightMinutes" />

                <label for="lying">@Lang.T("vitals.lying")</label>
                <input id="lying" type="number" min="0" max="1440" @bind="form.TimeLyingMinutes" />
            </section>

            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }

            <div class="action-row">
                <button type="submit" class="btn--primary" disabled="@busy">
                    <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                    <span class="arrow" aria-hidden="true">→</span>
                </button>
                <a href="/today" class="btn--ghost" style="text-decoration:none;text-align:center;display:inline-flex;align-items:center;justify-content:center;">
                    @Lang.T("cancel")
                </a>
            </div>
        </EditForm>
    }
</div>

@code {
    private VitalsForm form = new();
    private bool busy;
    private bool saved;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task SaveAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            await VitalClient.RecordAsync(new RecordVitalsDto
            {
                RestingHrBpm = form.RestingHrBpm,
                StandingHrBpm2Min = form.StandingHrBpm2Min,
                StandingHrBpm5Min = form.StandingHrBpm5Min,
                StandingHrBpm10Min = form.StandingHrBpm10Min,
                BpLyingSystolic = form.BpLyingSystolic,
                BpLyingDiastolic = form.BpLyingDiastolic,
                BpSittingSystolic = form.BpSittingSystolic,
                BpSittingDiastolic = form.BpSittingDiastolic,
                BpStandingSystolic = form.BpStandingSystolic,
                BpStandingDiastolic = form.BpStandingDiastolic,
                Spo2Percent = form.Spo2Percent,
                WeightKg = form.WeightKg,
                MenstrualCycleDay = form.MenstrualCycleDay,
                SleepDurationMinutes = form.SleepDurationMinutes,
                SleepQuality = form.SleepQuality,
                Steps = form.Steps,
                ExerciseMinutes = form.ExerciseMinutes,
                TimeUprightMinutes = form.TimeUprightMinutes,
                TimeLyingMinutes = form.TimeLyingMinutes,
                AmbientTempC = form.AmbientTempC,
            });
            saved = true;
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("common.saveError");
        }
        finally { busy = false; }
    }

    private void Reset()
    {
        form = new VitalsForm();
        saved = false;
        errorMessage = null;
    }

    private sealed class VitalsForm
    {
        public int? RestingHrBpm { get; set; }
        public int? StandingHrBpm2Min { get; set; }
        public int? StandingHrBpm5Min { get; set; }
        public int? StandingHrBpm10Min { get; set; }
        public int? BpLyingSystolic { get; set; }
        public int? BpLyingDiastolic { get; set; }
        public int? BpSittingSystolic { get; set; }
        public int? BpSittingDiastolic { get; set; }
        public int? BpStandingSystolic { get; set; }
        public int? BpStandingDiastolic { get; set; }
        public int? Spo2Percent { get; set; }
        public decimal? WeightKg { get; set; }
        public int? MenstrualCycleDay { get; set; }
        public int? SleepDurationMinutes { get; set; }
        public int? SleepQuality { get; set; }
        public int? Steps { get; set; }
        public int? ExerciseMinutes { get; set; }
        public int? TimeUprightMinutes { get; set; }
        public int? TimeLyingMinutes { get; set; }
        public decimal? AmbientTempC { get; set; }
    }
}
