@page "/report"
@inject AuthClient Auth
@inject ReportClient ReportClient
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("report.pageTitle")</PageTitle>

<div class="shell flow stagger no-print">
    <p class="eyebrow">@Lang.T("report.eyebrow")</p>
    <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("report.title"))</h1>
    <p class="lead">@Lang.T("report.lead")</p>

    <section class="card flow">
        <p class="card__label">@Lang.T("report.range.label")</p>
        <div class="action-row">
            <button class="@(days == 7 ? "btn--primary" : "btn--ghost")" @onclick="() => Reload(7)">@Lang.T("report.range.week")</button>
            <button class="@(days == 30 ? "btn--primary" : "btn--ghost")" @onclick="() => Reload(30)">@Lang.T("report.range.30d")</button>
            <button class="@(days == 90 ? "btn--primary" : "btn--ghost")" @onclick="() => Reload(90)">@Lang.T("report.range.90d")</button>
        </div>
    </section>
</div>

@if (loading)
{
    <div class="shell"><p>@Lang.T("report.loading")</p></div>
}
else if (report is null)
{
    <div class="shell"><p class="muted">@Lang.T("report.loadError")</p></div>
}
else
{
    <article class="print-sheet">
        <header class="print-sheet__head">
            <h2 class="print-sheet__title">@Lang.T("report.sheet.title")</h2>
            <p class="print-sheet__meta">
                @Lang.T("report.sheet.patient") <strong>@report.PatientName</strong><br />
                @Lang.T("report.sheet.period") @report.From.ToLocalTime().ToString("yyyy-MM-dd") → @report.To.ToLocalTime().ToString("yyyy-MM-dd")<br />
                @Lang.T("report.sheet.generated") @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
            </p>
            <p class="print-sheet__disclaimer">@Lang.T("report.sheet.disclaimer")</p>
        </header>

        <section class="print-sheet__section">
            <h3>@Lang.T("report.days.title")</h3>
            <table>
                <tr><th>@Lang.T("report.days.green")</th><td>@report.GreenCount</td></tr>
                <tr><th>@Lang.T("report.days.orange")</th><td>@report.OrangeCount</td></tr>
                <tr><th>@Lang.T("report.days.red")</th><td>@report.RedCount</td></tr>
                <tr><th>@Lang.T("report.days.episodes")</th><td>@report.EpisodeCount</td></tr>
                <tr><th>@Lang.T("report.days.prevented")</th><td>@report.EpisodesPreventedFainting</td></tr>
            </table>
        </section>

        <section class="print-sheet__section">
            <h3>@Lang.T("report.hrBp.title")</h3>
            <table>
                <tr><th>@Lang.T("report.hrBp.hrResting")</th><td>@FmtBpm(report.AvgRestingHrBpm)</td></tr>
                <tr><th>@Lang.T("report.hrBp.hrStanding")</th><td>@FmtBpm(report.AvgStandingHrBpm)</td></tr>
                <tr><th>@Lang.T("report.hrBp.bpLying")</th><td>@FmtBp(report.AvgBpLyingSys, report.AvgBpLyingDia)</td></tr>
                <tr><th>@Lang.T("report.hrBp.bpSitting")</th><td>@FmtBp(report.AvgBpSittingSys, report.AvgBpSittingDia)</td></tr>
                <tr><th>@Lang.T("report.hrBp.bpStanding")</th><td>@FmtBp(report.AvgBpStandingSys, report.AvgBpStandingDia)</td></tr>
                <tr><th>@Lang.T("report.hrBp.hrMaxEp")</th><td>@FmtBpm(report.MaxHrInEpisodeBpm.HasValue ? (double)report.MaxHrInEpisodeBpm.Value : null)</td></tr>
            </table>
        </section>

        @if (report.TopSymptoms.Count > 0)
        {
            <section class="print-sheet__section">
                <h3>@Lang.T("report.topSymptoms.title")</h3>
                <table>
                    @foreach (var s in report.TopSymptoms)
                    {
                        <tr><th>@s.Name</th><td>@s.Average.ToString("0.0")</td></tr>
                    }
                </table>
            </section>
        }

        @if (report.TopTriggers.Count > 0)
        {
            <section class="print-sheet__section">
                <h3>@Lang.T("report.topTriggers.title")</h3>
                <table>
                    @foreach (var t in report.TopTriggers)
                    {
                        <tr><th>@TriggerLabel(t.Trigger)</th><td>@t.Count @Lang.T("report.topTriggers.episodes")</td></tr>
                    }
                </table>
            </section>
        }

        <section class="print-sheet__section">
            <h3>@Lang.T("report.adherence.title")</h3>
            <table>
                <tr><th>@Lang.T("report.adherence.hydration")</th><td>@FmtMl(report.AvgDailyFluidMl)</td></tr>
                <tr><th>@Lang.T("report.adherence.compression")</th><td>@FmtPct(report.CompressionAdherencePct)</td></tr>
                <tr><th>@Lang.T("report.adherence.exercise")</th><td>@FmtPct(report.ExerciseAdherencePct)</td></tr>
                <tr><th>@Lang.T("report.adherence.medication")</th><td>@FmtPct(report.MedicationAdherencePct)</td></tr>
            </table>
        </section>

        <section class="print-sheet__section">
            <h3>@Lang.T("report.exTolerance.title")</h3>
            <table>
                <tr><th>@Lang.T("report.exTolerance.sessions")</th><td>@report.ExerciseSessions</td></tr>
                <tr><th>@Lang.T("report.exTolerance.withPost")</th>
                    <td>@report.ExerciseSessionsWithPostSymptoms
                        @if (report.ExerciseSessions > 0)
                        {
                            <text> · @($"{100.0 * report.ExerciseSessionsWithPostSymptoms / report.ExerciseSessions:0.0}%")</text>
                        }
                    </td></tr>
            </table>
            <p class="print-sheet__disclaimer">@Lang.T("report.exTolerance.disclaimer")</p>
        </section>

        @if (report.PatientNotes.Count > 0)
        {
            <section class="print-sheet__section">
                <h3>@Lang.T("report.notes.title")</h3>
                <ul class="print-sheet__notes">
                    @foreach (var n in report.PatientNotes)
                    {
                        <li>@n</li>
                    }
                </ul>
            </section>
        }
    </article>

    <div class="shell no-print">
        <hr class="divider divider--ornament" aria-hidden="true" />
        <div class="action-row">
            <button class="btn--primary" @onclick="PrintAsync">
                <span>@Lang.T("report.print")</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
            <a class="btn--ghost" href="@CsvDownloadUrl()" target="_blank" rel="noopener" style="text-decoration:none;text-align:center;display:inline-flex;align-items:center;justify-content:center;">
                @Lang.T("report.csv")
            </a>
            <a href="/today" class="btn--quiet" style="text-decoration:none;align-self:center;">@Lang.T("report.back")</a>
        </div>
    </div>
}

@code {
    private DoctorReportDto? report;
    private bool loading = true;
    private int days = 30;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await Reload(30);
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task Reload(int newDays)
    {
        days = newDays;
        loading = true;
        try
        {
            var to = DateTimeOffset.UtcNow;
            var from = to.AddDays(-newDays);
            report = await ReportClient.GetAsync(from, to);
        }
        catch (HttpRequestException) { report = null; }
        finally { loading = false; }
    }

    private async Task PrintAsync()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private string CsvDownloadUrl()
    {
        // Direct download won't carry the JWT — for v1 we open with the token
        // appended in fragment is not supported; the simpler dev path is to
        // ask the user to download via the API directly. TODO: add a one-shot
        // signed URL endpoint for downloads from PWA.
        var to = DateTimeOffset.UtcNow;
        var from = to.AddDays(-days);
        // Note: in production wire this through a signed-URL endpoint.
        return ReportClient.CsvUrl(from, to);
    }

    private static string FmtBpm(double? v) => v.HasValue ? $"{v.Value:0} lpm" : "—";
    private static string FmtBp(double? sys, double? dia) =>
        (sys.HasValue && dia.HasValue) ? $"{sys.Value:0} / {dia.Value:0} mmHg" : "—";
    private static string FmtMl(double? v) => v.HasValue ? $"{v.Value:0} ml" : "—";
    private static string FmtPct(double? v) => v.HasValue ? $"{v.Value:0.0} %" : "—";

    // Localized short label for a backend trigger enum. Falls back to the raw
    // enum name if no translation key matches.
    private string TriggerLabel(string trigger) => trigger switch
    {
        "Unknown" => Lang.T("trigger.short.unknown"),
        "Heat" => Lang.T("trigger.heat"),
        "Dehydration" => Lang.T("trigger.dehydration"),
        "MissedMeal" => Lang.T("trigger.short.missedMeal"),
        "Menstrual" => Lang.T("trigger.menstrual"),
        "Stress" => Lang.T("trigger.stress"),
        "PoorSleep" => Lang.T("trigger.poorSleep"),
        "Exercise" => Lang.T("trigger.exercise"),
        "Infection" => Lang.T("trigger.infection"),
        "LongStanding" => Lang.T("trigger.short.longStanding"),
        "Alcohol" => Lang.T("trigger.alcohol"),
        "LargeMeal" => Lang.T("trigger.short.largeMeal"),
        _ => trigger,
    };
}
