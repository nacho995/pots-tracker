@page "/report"
@inject AuthClient Auth
@inject ReportClient ReportClient
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Informe — POTS</PageTitle>

<div class="shell flow stagger no-print">
    <p class="eyebrow">Informe para tu médico</p>
    <h1><span class="accent-rule"></span>Listo para llevar<br />a la consulta.</h1>
    <p class="lead">
        Un resumen de tu seguimiento. Imprime como PDF desde el navegador o
        descarga el CSV.
    </p>

    <section class="card flow">
        <p class="card__label">Rango</p>
        <div class="action-row">
            <button class="@(days == 7 ? "btn--primary" : "btn--ghost")" @onclick="() => Reload(7)">Última semana</button>
            <button class="@(days == 30 ? "btn--primary" : "btn--ghost")" @onclick="() => Reload(30)">Últimos 30 días</button>
            <button class="@(days == 90 ? "btn--primary" : "btn--ghost")" @onclick="() => Reload(90)">Últimos 90 días</button>
        </div>
    </section>
</div>

@if (loading)
{
    <div class="shell"><p>Cargando informe...</p></div>
}
else if (report is null)
{
    <div class="shell"><p class="muted">No se pudo cargar el informe.</p></div>
}
else
{
    <article class="print-sheet">
        <header class="print-sheet__head">
            <h2 class="print-sheet__title">POTS · Resumen de seguimiento</h2>
            <p class="print-sheet__meta">
                Paciente: <strong>@report.PatientName</strong><br />
                Periodo: @report.From.ToLocalTime().ToString("yyyy-MM-dd") → @report.To.ToLocalTime().ToString("yyyy-MM-dd")<br />
                Generado: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
            </p>
            <p class="print-sheet__disclaimer">
                Esto es una herramienta de seguimiento auto-registrado, no un
                informe clínico. Las observaciones de patrones se presentan
                como <em>asociaciones</em>, no como diagnósticos.
            </p>
        </header>

        <section class="print-sheet__section">
            <h3>Días según el paciente</h3>
            <table>
                <tr><th>Bien (verde)</th><td>@report.GreenCount</td></tr>
                <tr><th>Regular (naranja)</th><td>@report.OrangeCount</td></tr>
                <tr><th>Mal (rojo)</th><td>@report.RedCount</td></tr>
                <tr><th>Episodios registrados</th><td>@report.EpisodeCount</td></tr>
                <tr><th>Episodios con desmayo evitado por maniobras</th><td>@report.EpisodesPreventedFainting</td></tr>
            </table>
        </section>

        <section class="print-sheet__section">
            <h3>Frecuencia cardíaca y tensión arterial (medias)</h3>
            <table>
                <tr><th>HR en reposo</th><td>@FmtBpm(report.AvgRestingHrBpm)</td></tr>
                <tr><th>HR de pie (mejor medida disponible)</th><td>@FmtBpm(report.AvgStandingHrBpm)</td></tr>
                <tr><th>BP tumbada (sis/dia)</th><td>@FmtBp(report.AvgBpLyingSys, report.AvgBpLyingDia)</td></tr>
                <tr><th>BP sentada (sis/dia)</th><td>@FmtBp(report.AvgBpSittingSys, report.AvgBpSittingDia)</td></tr>
                <tr><th>BP de pie (sis/dia)</th><td>@FmtBp(report.AvgBpStandingSys, report.AvgBpStandingDia)</td></tr>
                <tr><th>HR máxima durante episodio</th><td>@FmtBpm(report.MaxHrInEpisodeBpm.HasValue ? (double)report.MaxHrInEpisodeBpm.Value : null)</td></tr>
            </table>
        </section>

        @if (report.TopSymptoms.Count > 0)
        {
            <section class="print-sheet__section">
                <h3>Síntomas más prominentes (media 0-10)</h3>
                <table>
                    @foreach (var s in report.TopSymptoms)
                    {
                        <tr><th>@s.Name</th><td>@s.Average.ToString("0.0")</td></tr>
                    }
                </table>
            </section>
        }

        @if (report.TopTriggers.Count > 0)
        {
            <section class="print-sheet__section">
                <h3>Desencadenantes sospechosos (anotados por la paciente)</h3>
                <table>
                    @foreach (var t in report.TopTriggers)
                    {
                        <tr><th>@TriggerEs(t.Trigger)</th><td>@t.Count episodios</td></tr>
                    }
                </table>
            </section>
        }

        <section class="print-sheet__section">
            <h3>Adherencia a las medidas no-farmacológicas</h3>
            <table>
                <tr><th>Hidratación (media ml/día)</th><td>@FmtMl(report.AvgDailyFluidMl)</td></tr>
                <tr><th>Compresión (% días)</th><td>@FmtPct(report.CompressionAdherencePct)</td></tr>
                <tr><th>Ejercicio (% días con alguna sesión)</th><td>@FmtPct(report.ExerciseAdherencePct)</td></tr>
                <tr><th>Medicación según prescripción (% días)</th><td>@FmtPct(report.MedicationAdherencePct)</td></tr>
            </table>
        </section>

        <section class="print-sheet__section">
            <h3>Tolerancia al ejercicio</h3>
            <table>
                <tr><th>Sesiones de ejercicio registradas</th><td>@report.ExerciseSessions</td></tr>
                <tr><th>Sesiones con síntomas post-ejercicio anotados</th>
                    <td>@report.ExerciseSessionsWithPostSymptoms
                        @if (report.ExerciseSessions > 0)
                        {
                            <text> · @($"{100.0 * report.ExerciseSessionsWithPostSymptoms / report.ExerciseSessions:0.0}%")</text>
                        }
                    </td></tr>
            </table>
            <p class="print-sheet__disclaimer">
                Un % alto sugiere que la paciente está sobrepasando su umbral
                de tolerancia ese tipo de día. Asociación, no causalidad.
            </p>
        </section>

        @if (report.PatientNotes.Count > 0)
        {
            <section class="print-sheet__section">
                <h3>Notas de la paciente</h3>
                <ul class="print-sheet__notes">
                    @foreach (var n in report.PatientNotes)
                    {
                        <li>@n</li>
                    }
                </ul>
            </section>
        }
    </article>

    <div class="shell no-print">
        <hr class="divider divider--ornament" aria-hidden="true" />
        <div class="action-row">
            <button class="btn--primary" @onclick="PrintAsync">
                <span>Imprimir / guardar como PDF</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
            <a class="btn--ghost" href="@CsvDownloadUrl()" target="_blank" rel="noopener" style="text-decoration:none;text-align:center;display:inline-flex;align-items:center;justify-content:center;">
                Descargar CSV
            </a>
            <a href="/today" class="btn--quiet" style="text-decoration:none;align-self:center;">Volver</a>
        </div>
    </div>
}

@code {
    private DoctorReportDto? report;
    private bool loading = true;
    private int days = 30;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await Reload(30);
    }

    private async Task Reload(int newDays)
    {
        days = newDays;
        loading = true;
        try
        {
            var to = DateTimeOffset.UtcNow;
            var from = to.AddDays(-newDays);
            report = await ReportClient.GetAsync(from, to);
        }
        catch (HttpRequestException) { report = null; }
        finally { loading = false; }
    }

    private async Task PrintAsync()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private string CsvDownloadUrl()
    {
        // Direct download won't carry the JWT — for v1 we open with the token
        // appended in fragment is not supported; the simpler dev path is to
        // ask the user to download via the API directly. TODO: add a one-shot
        // signed URL endpoint for downloads from PWA.
        var to = DateTimeOffset.UtcNow;
        var from = to.AddDays(-days);
        // Note: in production wire this through a signed-URL endpoint.
        return ReportClient.CsvUrl(from, to);
    }

    private static string FmtBpm(double? v) => v.HasValue ? $"{v.Value:0} lpm" : "—";
    private static string FmtBp(double? sys, double? dia) =>
        (sys.HasValue && dia.HasValue) ? $"{sys.Value:0} / {dia.Value:0} mmHg" : "—";
    private static string FmtMl(double? v) => v.HasValue ? $"{v.Value:0} ml" : "—";
    private static string FmtPct(double? v) => v.HasValue ? $"{v.Value:0.0} %" : "—";

    private static readonly Dictionary<string, string> TriggerLabels = new()
    {
        ["Unknown"] = "Desconocido",
        ["Heat"] = "Calor",
        ["Dehydration"] = "Deshidratación",
        ["MissedMeal"] = "Saltar comida",
        ["Menstrual"] = "Menstruación",
        ["Stress"] = "Estrés",
        ["PoorSleep"] = "Mal sueño",
        ["Exercise"] = "Ejercicio",
        ["Infection"] = "Infección",
        ["LongStanding"] = "Mucho de pie",
        ["Alcohol"] = "Alcohol",
        ["LargeMeal"] = "Comida grande",
    };

    private static string TriggerEs(string trigger) =>
        TriggerLabels.TryGetValue(trigger, out var es) ? es : trigger;
}
