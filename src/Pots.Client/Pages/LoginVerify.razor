@page "/login/verify"
@inject AuthClient Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LanguageService Lang
@implements IDisposable

<PageTitle>POTS</PageTitle>

<div class="shell shell--narrow flow stagger">
    <p class="eyebrow">@Lang.T("loginVerify.eyebrow")</p>

    @if (errorMessage is null)
    {
        <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("loginVerify.checking.title"))</h1>
        <p class="lead">@Lang.T("loginVerify.checking.lead")</p>
    }
    else
    {
        <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("loginVerify.invalid.title"))</h1>
        <p class="lead">@errorMessage</p>
        <a href="/login" class="btn--link">@Lang.T("loginVerify.requestNew")</a>
    }
</div>

@code {
    private string? errorMessage;

    protected override void OnInitialized()
    {
        Lang.LanguageChanged += OnLangChanged;
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var hash = await JS.InvokeAsync<string>("eval", "window.location.hash");
        var rawToken = ExtractToken(hash);

        if (string.IsNullOrEmpty(rawToken))
        {
            errorMessage = Lang.T("loginVerify.error.incomplete");
            StateHasChanged();
            return;
        }

        var ok = await Auth.VerifyAsync(rawToken);
        if (ok)
        {
            await JS.InvokeVoidAsync("history.replaceState", null, "", "/today");
            Nav.NavigateTo("/today", replace: true);
        }
        else
        {
            errorMessage = Lang.T("loginVerify.error.expired");
            StateHasChanged();
        }
    }

    private static string? ExtractToken(string hash)
    {
        if (string.IsNullOrEmpty(hash)) return null;
        var trimmed = hash.TrimStart('#');
        foreach (var part in trimmed.Split('&'))
        {
            var eq = part.IndexOf('=');
            if (eq < 0) continue;
            var key = part[..eq];
            if (key == "token") return Uri.UnescapeDataString(part[(eq + 1)..]);
        }
        return null;
    }
}
