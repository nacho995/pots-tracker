@page "/shared"
@inject AuthClient Auth
@inject SharedClient SharedClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("shared.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("shared.eyebrow")</p>
    <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("shared.title"))</h1>
    <p class="lead">@Lang.T("shared.lead")</p>

    <hr class="divider" aria-hidden="true" />

    @if (loading)
    {
        <p>@Lang.T("loading")...</p>
    }
    else if (shared.Count == 0)
    {
        <p class="muted">@Lang.T("shared.empty")</p>
    }
    else
    {
        <ul class="shared-list">
            @foreach (var s in shared)
            {
                <li class="shared-card">
                    @* Whole card is the link so the touch target is the full
                       row (≥48px). The <a> wraps the content rather than the
                       <li> so the list semantics for screen readers stay
                       intact. *@
                    <a href="@($"/shared/{s.PatientId}")" class="shared-card__link">
                        <p class="card__label">@(s.Role == "Editor" ? Lang.T("grants.list.roleEditor") : Lang.T("grants.list.roleViewer")) · @Lang.T("grants.list.since").ToLower() @s.GrantedAt.ToLocalTime().ToString("yyyy-MM-dd")</p>
                        <h2>@s.PatientName</h2>
                        <p class="muted">@Lang.T("shared.owner") @s.OwnerEmail</p>
                        <span class="shared-card__chev" aria-hidden="true">→</span>
                        @* Screen-reader-only label. The chev is decorative; this
                           is what assistive tech announces as the link target. *@
                        <span class="visually-hidden">@string.Format(Lang.T("shared.card.openFor"), s.PatientName)</span>
                    </a>
                </li>
            }
        </ul>
    }

    <hr class="divider divider--ornament" aria-hidden="true" />

    <p class="muted" style="text-align:center;">
        <a href="/today" class="btn--link">@Lang.T("shared.linkToday")</a>
        &nbsp;·&nbsp;
        <a href="/profile" class="btn--link">@Lang.T("shared.linkProfile")</a>
    </p>
</div>

@code {
    private List<SharedPatientDto> shared = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        try { shared = await SharedClient.ListAsync(); }
        catch { /* keep empty */ }
        finally { loading = false; }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;
}
