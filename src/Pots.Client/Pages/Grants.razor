@page "/grants"
@inject AuthClient Auth
@inject GrantClient GrantClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("grants.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("grants.eyebrow")</p>

    <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("grants.title"))</h1>

    <p class="lead">@Lang.T("grants.lead")</p>

    <hr class="divider" aria-hidden="true" />

    <section class="card">
        <p class="card__label">@Lang.T("grants.invite.label")</p>
        <EditForm Model="this" OnValidSubmit="InviteAsync">
            <div>
                <label for="grantee-email">@Lang.T("grants.invite.email")</label>
                <input id="grantee-email" type="email" inputmode="email" autocomplete="email"
                       placeholder="@Lang.T("grants.invite.emailPlaceholder")" @bind="emailInput" required disabled="@busy" />
            </div>

            <fieldset class="role-fieldset">
                <legend>@Lang.T("grants.invite.typeLegend")</legend>
                <label class="role-row">
                    <input type="radio" name="role" value="Viewer"
                           checked="@(roleInput == "Viewer")"
                           @onchange="@(_ => roleInput = "Viewer")" />
                    <span>
                        <span class="role-row__title">@Lang.T("grants.invite.viewer")</span>
                        <span class="role-row__hint">@Lang.T("grants.invite.viewer.hint")</span>
                    </span>
                </label>
                <label class="role-row">
                    <input type="radio" name="role" value="Editor"
                           checked="@(roleInput == "Editor")"
                           @onchange="@(_ => roleInput = "Editor")" />
                    <span>
                        <span class="role-row__title">@Lang.T("grants.invite.editor")</span>
                        <span class="role-row__hint">@Lang.T("grants.invite.editor.hint")</span>
                    </span>
                </label>
            </fieldset>

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>
                    @(busy
                        ? Lang.T("grants.invite.sending")
                        : (roleInput == "Editor" ? Lang.T("grants.invite.inviteToEdit") : Lang.T("grants.invite.inviteToView")))
                </span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        @if (inviteMessage is not null)
        {
            <p class="@(inviteOk ? "muted" : "error-text")" role="status">@inviteMessage</p>
        }
    </section>

    <section class="card card--sunk">
        <p class="card__label">@Lang.T("grants.list.label")</p>
        @if (loading)
        {
            <p>@Lang.T("loading")...</p>
        }
        else if (grants.Count == 0)
        {
            <p class="muted">@Lang.T("grants.list.empty")</p>
        }
        else
        {
            <ul class="grant-list">
                @foreach (var g in grants)
                {
                    <li class="grant-row">
                        <div>
                            <p class="grant-row__email">@g.GranteeEmail</p>
                            <p class="grant-row__meta">
                                <span class="grant-row__role-tag">
                                    @(g.Role == "Editor" ? Lang.T("grants.list.roleEditor") : Lang.T("grants.list.roleViewer"))
                                </span>
                                @Lang.T("grants.list.since") @g.GrantedAt.ToLocalTime().ToString("yyyy-MM-dd")
                            </p>
                        </div>
                        <button class="btn--quiet" @onclick="@(() => RevokeAsync(g.Id))" disabled="@busy">
                            @Lang.T("grants.list.revoke")
                        </button>
                    </li>
                }
            </ul>
        }
    </section>

    <hr class="divider divider--ornament" aria-hidden="true" />

    <a href="/profile" class="btn--link">@Lang.T("grants.back")</a>
</div>

@code {
    private string emailInput = "";
    private string roleInput = "Viewer";
    private List<GrantDto> grants = new();
    private bool loading = true;
    private bool busy = false;
    private string? inviteMessage;
    private bool inviteOk = false;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await LoadAsync();
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task LoadAsync()
    {
        loading = true;
        try { grants = await GrantClient.ListAsync(); }
        catch { /* keep current list */ }
        finally { loading = false; }
    }

    private async Task InviteAsync()
    {
        inviteMessage = null; busy = true;
        try
        {
            var (ok, code) = await GrantClient.InviteAsync(emailInput, roleInput);
            if (ok)
            {
                inviteOk = true;
                inviteMessage = string.Format(Lang.T("grants.invite.ok"), emailInput);
                emailInput = "";
                await LoadAsync();
            }
            else
            {
                inviteOk = false;
                inviteMessage = code switch
                {
                    "grant.already_active" => Lang.T("grants.error.alreadyActive"),
                    "grant.invalid_email" => Lang.T("grants.error.invalidEmail"),
                    "grant.self_grant_not_allowed" => Lang.T("grants.error.selfGrant"),
                    _ => Lang.T("grants.error.generic")
                };
            }
        }
        finally { busy = false; }
    }

    private async Task RevokeAsync(Guid grantId)
    {
        busy = true;
        try { await GrantClient.RevokeAsync(grantId); await LoadAsync(); }
        finally { busy = false; }
    }
}
