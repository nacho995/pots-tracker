@page "/grants"
@inject AuthClient Auth
@inject GrantClient GrantClient
@inject GrantUpgradeClient Upgrades
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("grants.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("grants.eyebrow")</p>

    <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("grants.title"))</h1>

    <p class="lead">@Lang.T("grants.lead")</p>

    <hr class="divider" aria-hidden="true" />

    <section class="card">
        <p class="card__label">@Lang.T("grants.invite.label")</p>
        <EditForm Model="this" OnValidSubmit="InviteAsync">
            <div>
                <label for="grantee-email">@Lang.T("grants.invite.email")</label>
                <input id="grantee-email" type="email" inputmode="email" autocomplete="email"
                       placeholder="@Lang.T("grants.invite.emailPlaceholder")" @bind="emailInput" required disabled="@busy" />
            </div>

            @* Phase 3: invitations are always Viewer. To grant write access,
               the invitee asks from her shared dashboard and we surface the
               request below; no more "Editor at invite" tickbox. *@
            <p class="muted">@Lang.T("grants.invite.viewerOnlyNote")</p>

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>@(busy ? Lang.T("grants.invite.sending") : Lang.T("grants.invite.inviteToView"))</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        @if (inviteMessage is not null)
        {
            <p class="@(inviteOk ? "muted" : "error-text")" role="status">@inviteMessage</p>
        }
    </section>

    @if (pendingRequests.Count > 0)
    {
        <section class="card flow">
            <p class="card__label">@Lang.T("grants.upgradeRequests.label")</p>
            <h2>@Lang.T("grants.upgradeRequests.title")</h2>
            <p class="muted">@Lang.T("grants.upgradeRequests.help")</p>
            <ul class="grant-list">
                @foreach (var r in pendingRequests)
                {
                    <li class="grant-row">
                        <div>
                            <p class="grant-row__email">@r.RequesterEmail</p>
                            <p class="grant-row__meta">
                                @Lang.T("grants.upgradeRequests.since") @r.RequestedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </p>
                            @if (!string.IsNullOrWhiteSpace(r.Message))
                            {
                                <p class="grant-row__message">"@r.Message"</p>
                            }
                        </div>
                        <div class="action-row">
                            <button class="btn--primary" style="display:inline-flex;width:auto;"
                                    @onclick="@(() => ApproveAsync(r.RequestId))" disabled="@busy">
                                <span>@Lang.T("grants.upgradeRequests.approve")</span>
                            </button>
                            <button class="btn--quiet"
                                    @onclick="@(() => DenyAsync(r.RequestId))" disabled="@busy">
                                @Lang.T("grants.upgradeRequests.deny")
                            </button>
                        </div>
                    </li>
                }
            </ul>
            @if (upgradeMessage is not null)
            {
                <p class="muted" role="status">@upgradeMessage</p>
            }
        </section>
    }

    <section class="card card--sunk">
        <p class="card__label">@Lang.T("grants.list.label")</p>
        @if (loading)
        {
            <p>@Lang.T("loading")...</p>
        }
        else if (grants.Count == 0)
        {
            <p class="muted">@Lang.T("grants.list.empty")</p>
        }
        else
        {
            <ul class="grant-list">
                @foreach (var g in grants)
                {
                    <li class="grant-row">
                        <div>
                            <p class="grant-row__email">@g.GranteeEmail</p>
                            <p class="grant-row__meta">
                                <span class="grant-row__role-tag">
                                    @(g.Role == "Editor" ? Lang.T("grants.list.roleEditor") : Lang.T("grants.list.roleViewer"))
                                </span>
                                @Lang.T("grants.list.since") @g.GrantedAt.ToLocalTime().ToString("yyyy-MM-dd")
                            </p>
                        </div>
                        <div class="action-row">
                            @* Phase 7.1: direct toggle Viewer↔Editor from the
                               owner side. Complementary to the
                               request-upgrade flow, which is still useful
                               for caregiver-initiated promotion when the
                               owner is offline. *@
                            @if (g.Role == "Viewer")
                            {
                                <button class="btn--link"
                                        @onclick="@(() => SetRoleAsync(g.Id, "Editor"))"
                                        disabled="@busy">
                                    @Lang.T("grants.list.promote")
                                </button>
                            }
                            else
                            {
                                <button class="btn--link"
                                        @onclick="@(() => SetRoleAsync(g.Id, "Viewer"))"
                                        disabled="@busy">
                                    @Lang.T("grants.list.demote")
                                </button>
                            }
                            <button class="btn--quiet" @onclick="@(() => RevokeAsync(g.Id))" disabled="@busy">
                                @Lang.T("grants.list.revoke")
                            </button>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>

    <hr class="divider divider--ornament" aria-hidden="true" />

    <a href="/profile" class="btn--link">@Lang.T("grants.back")</a>
</div>

@code {
    private string emailInput = "";
    private List<GrantDto> grants = new();
    private List<GrantUpgradeRequestDto> pendingRequests = new();
    private bool loading = true;
    private bool busy = false;
    private string? inviteMessage;
    private bool inviteOk = false;
    private string? upgradeMessage;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await LoadAsync();
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task LoadAsync()
    {
        loading = true;
        // Each fetch is guarded individually so a transient failure in one
        // (e.g. the upgrade-requests endpoint) doesn't blank BOTH lists.
        // Bug seen in production v1.0: a failed pendingRequests fetch via
        // Task.WhenAll propagated and the outer catch silently emptied the
        // grants list too, making fresh invitations look as if they had
        // never happened.
        try { grants = await GrantClient.ListAsync(); } catch { /* keep */ }
        try { pendingRequests = await Upgrades.ListPendingForMyPatientAsync(); } catch { /* keep */ }
        loading = false;
    }

    private async Task InviteAsync()
    {
        inviteMessage = null; busy = true;
        try
        {
            // Phase 3: server locks the role to Viewer. We still send the
            // string for backward compatibility with the existing GrantClient
            // signature; sending anything other than "Viewer" returns 400.
            var (ok, code) = await GrantClient.InviteAsync(emailInput, "Viewer");
            if (ok)
            {
                inviteOk = true;
                inviteMessage = string.Format(Lang.T("grants.invite.ok"), emailInput);
                emailInput = "";
                await LoadAsync();
            }
            else
            {
                inviteOk = false;
                inviteMessage = code switch
                {
                    "grant.already_active" => Lang.T("grants.error.alreadyActive"),
                    "grant.invalid_email" => Lang.T("grants.error.invalidEmail"),
                    "grant.self_grant_not_allowed" => Lang.T("grants.error.selfGrant"),
                    _ => Lang.T("grants.error.generic")
                };
            }
        }
        finally { busy = false; }
    }

    private async Task RevokeAsync(Guid grantId)
    {
        busy = true;
        try { await GrantClient.RevokeAsync(grantId); await LoadAsync(); }
        finally { busy = false; }
    }

    private async Task SetRoleAsync(Guid grantId, string role)
    {
        busy = true;
        try { await GrantClient.SetRoleAsync(grantId, role); await LoadAsync(); }
        catch { /* fail silent: keep list */ }
        finally { busy = false; }
    }

    private async Task ApproveAsync(Guid requestId)
    {
        busy = true; upgradeMessage = null;
        try
        {
            await Upgrades.ApproveAsync(requestId);
            upgradeMessage = Lang.T("grants.upgradeRequests.approveOk");
            await LoadAsync();
        }
        catch
        {
            upgradeMessage = Lang.T("grants.upgradeRequests.error");
        }
        finally { busy = false; }
    }

    private async Task DenyAsync(Guid requestId)
    {
        busy = true; upgradeMessage = null;
        try
        {
            await Upgrades.DenyAsync(requestId);
            upgradeMessage = Lang.T("grants.upgradeRequests.denyOk");
            await LoadAsync();
        }
        catch
        {
            upgradeMessage = Lang.T("grants.upgradeRequests.error");
        }
        finally { busy = false; }
    }
}
