@page "/log"
@inject AuthClient Auth
@inject NavigationManager Nav

<PageTitle>Registrar — POTS</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">Registrar</p>
    <h1><span class="accent-rule"></span>¿Qué quieres<br />apuntar?</h1>
    <p class="lead">Cuatro formas de dejar constancia. Solo lo que te apetezca.</p>

    <div class="log-grid">
        <a href="/log/symptoms" class="log-tile">
            <span class="log-tile__num" aria-hidden="true">·</span>
            <span class="log-tile__title">Síntomas</span>
            <span class="log-tile__hint">Escalas 0-10 de cómo te encuentras ahora mismo.</span>
        </a>
        <a href="/log/vitals" class="log-tile">
            <span class="log-tile__num" aria-hidden="true">·</span>
            <span class="log-tile__title">Vitales</span>
            <span class="log-tile__hint">Pulso, tensión, sueño, pasos, ejercicio.</span>
        </a>
        <a href="/log/actions" class="log-tile">
            <span class="log-tile__num" aria-hidden="true">·</span>
            <span class="log-tile__title">Acciones del día</span>
            <span class="log-tile__hint">Hidratación, compresión, pacing, medicación.</span>
        </a>
        <a href="/episode/new" class="log-tile log-tile--accent">
            <span class="log-tile__num" aria-hidden="true">!</span>
            <span class="log-tile__title">Episodio</span>
            <span class="log-tile__hint">Para registrar un episodio severo después.</span>
        </a>
    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }
}
