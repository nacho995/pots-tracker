@page "/log/actions"
@page "/shared/{PatientId:guid}/log/actions"
@inject AuthClient Auth
@inject ActionClient ActionClient
@inject TargetsClient TargetsClient
@inject SharedPatientClient SharedPatients
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("actions.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("actions.eyebrow") · @FormatToday()</p>

    @if (saved)
    {
        <h1><span class="accent-rule"></span>@Lang.T("actions.saved.title")</h1>
        <p class="lead">@Lang.T("actions.saved.lead")</p>
        <a href="/today" class="btn--primary" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5em;text-decoration:none;width:auto;">
            <span>@Lang.T("common.backToToday")</span><span class="arrow" aria-hidden="true">→</span>
        </a>
    }
    else
    {
        <h1><span class="accent-rule"></span>@Lang.T("actions.title")</h1>
        <p class="lead">@Lang.T("actions.lead")</p>

        <EditForm Model="this" OnValidSubmit="SaveAsync" class="flow">

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.hydration.label")</p>
                <label for="fluid">@Lang.T("actions.hydration.fluid")</label>
                <input id="fluid" type="number" min="0" max="20000" @bind="form.FluidMl" placeholder="2500" />

                <label class="checkbox-row"><input type="checkbox" @bind="form.ElectrolyteTaken" /><span>@Lang.T("actions.hydration.electrolyte")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.MorningWaterBeforeStanding" /><span>@Lang.T("actions.hydration.morningWater")</span></label>

                <label for="urine">@Lang.T("actions.hydration.urineColor")</label>
                <select id="urine" class="text-input" @bind="form.UrineColor">
                    <option value="">@Lang.T("common.unspecified")</option>
                    <option value="Pale">@Lang.T("actions.hydration.urine.pale")</option>
                    <option value="Dark">@Lang.T("actions.hydration.urine.dark")</option>
                    <option value="Unsure">@Lang.T("actions.hydration.urine.unsure")</option>
                </select>
            </section>

            @* Salt is clinician-gated (CLAUDE.md §2): the field only renders when
               the patient has explicitly enabled the salt target. Never default on. *@
            @if (saltTargetEnabled)
            {
                <section class="card flow">
                    <p class="card__label">@Lang.T("actions.salt.label")</p>
                    <label class="checkbox-row">
                        <input type="checkbox" @bind="form.SaltTargetReached" />
                        <span>@Lang.T("actions.salt.reached")</span>
                    </label>
                </section>
            }

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.nutrition.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.RegularMeals" /><span>@Lang.T("actions.nutrition.regular")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.SkippedBreakfast" /><span>@Lang.T("actions.nutrition.skippedBreakfast")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.SmallFrequentMeals" /><span>@Lang.T("actions.nutrition.smallFrequent")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AvoidedLargeHighCarbMeal" /><span>@Lang.T("actions.nutrition.avoidedBig")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AdequateProtein" /><span>@Lang.T("actions.nutrition.protein")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AlcoholAvoided" /><span>@Lang.T("actions.nutrition.noAlcohol")</span></label>

                <label for="caffeine">@Lang.T("actions.nutrition.caffeine")</label>
                <select id="caffeine" class="text-input" @bind="form.CaffeineLevel">
                    <option value="None">@Lang.T("actions.nutrition.caffeine.none")</option>
                    <option value="Low">@Lang.T("actions.nutrition.caffeine.low")</option>
                    <option value="Moderate">@Lang.T("actions.nutrition.caffeine.moderate")</option>
                    <option value="High">@Lang.T("actions.nutrition.caffeine.high")</option>
                </select>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.compression.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.CompressionSocks" /><span>@Lang.T("actions.compression.socks")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.WaistHighCompression" /><span>@Lang.T("actions.compression.waist")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AbdominalCompression" /><span>@Lang.T("actions.compression.abdominal")</span></label>
                <label for="comp-hours">@Lang.T("actions.compression.hours")</label>
                <input id="comp-hours" type="number" min="0" max="24" @bind="form.CompressionHoursWorn" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.exercise.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.RecumbentExercise" /><span>@Lang.T("actions.exercise.recumbent")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.Walking" /><span>@Lang.T("actions.exercise.walking")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.Strength" /><span>@Lang.T("actions.exercise.strength")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.Stretching" /><span>@Lang.T("actions.exercise.stretching")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.PtExercises" /><span>@Lang.T("actions.exercise.pt")</span></label>
                <label for="ex-min">@Lang.T("actions.exercise.duration")</label>
                <input id="ex-min" type="number" min="0" max="1440" @bind="form.ExerciseDurationMinutes" />
                <label for="ex-int">@Lang.T("actions.exercise.intensity")</label>
                <input id="ex-int" type="text" maxlength="50" @bind="form.ExerciseIntensity" placeholder="@Lang.T("actions.exercise.intensity.placeholder")" />
                <label for="post-ex">@Lang.T("actions.exercise.post")</label>
                <input id="post-ex" type="text" maxlength="500" @bind="form.PostExerciseSymptoms" placeholder="@Lang.T("actions.exercise.post.placeholder")" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.pacing.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.PlannedRestBreaks" /><span>@Lang.T("actions.pacing.rest")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AvoidedOverexertion" /><span>@Lang.T("actions.pacing.noOver")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.UsedActivityPacing" /><span>@Lang.T("actions.pacing.applied")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AvoidedLongStanding" /><span>@Lang.T("actions.pacing.noLongStanding")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.SatDuringShowerCooking" /><span>@Lang.T("actions.pacing.satShower")</span></label>
                <label for="mobility">@Lang.T("actions.pacing.mobility")</label>
                <input id="mobility" type="text" maxlength="100" @bind="form.MobilityAid" placeholder="@Lang.T("actions.pacing.mobility.placeholder")" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.heat.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AvoidedHeat" /><span>@Lang.T("actions.heat.avoid")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.UsedCoolingVestFan" /><span>@Lang.T("actions.heat.cooling")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.ColdShower" /><span>@Lang.T("actions.heat.coldShower")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.AvoidedHotBathSauna" /><span>@Lang.T("actions.heat.noHotBath")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.StayedInShadeAc" /><span>@Lang.T("actions.heat.shade")</span></label>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.sleep.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.SleptEnough" /><span>@Lang.T("actions.sleep.enough")</span></label>
                <SymptomScale Label="@Lang.T("actions.sleep.quality")" @bind-Value="form.SleepQuality" />
                <label class="checkbox-row"><input type="checkbox" @bind="form.ConsistentBedtimes" /><span>@Lang.T("actions.sleep.consistent")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.NapTaken" /><span>@Lang.T("actions.sleep.nap")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="wokeRefreshedYes" /><span>@Lang.T("actions.sleep.refreshed")</span></label>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("actions.med.label")</p>
                <label class="checkbox-row"><input type="checkbox" @bind="form.MedicationTakenAsPrescribed" /><span>@Lang.T("actions.med.taken")</span></label>
                <label class="checkbox-row"><input type="checkbox" @bind="form.MissedDose" /><span>@Lang.T("actions.med.missed")</span></label>
                <label for="side">@Lang.T("actions.med.side")</label>
                <input id="side" type="text" maxlength="500" @bind="form.SideEffects" placeholder="@Lang.T("actions.med.side.placeholder")" />
                <label for="newmed">@Lang.T("actions.med.new")</label>
                <input id="newmed" type="text" maxlength="200" @bind="form.NewMedicationOrSupplement" />
                <label class="checkbox-row"><input type="checkbox" @bind="rescueMedYes" /><span>@Lang.T("actions.med.rescue")</span></label>
            </section>

            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }

            <div class="action-row">
                <button type="submit" class="btn--primary" disabled="@busy">
                    <span>@(busy ? Lang.T("saving") : Lang.T("actions.saveBtn"))</span>
                    <span class="arrow" aria-hidden="true">→</span>
                </button>
                <a href="/today" class="btn--ghost" style="text-decoration:none;text-align:center;display:inline-flex;align-items:center;justify-content:center;">
                    @Lang.T("cancel")
                </a>
            </div>
        </EditForm>
    }
</div>

@code {
    private ActionsForm form = new();
    private bool wokeRefreshedYes;
    private bool rescueMedYes;
    private bool saltTargetEnabled = false;
    private bool busy;
    private bool saved;

    [Parameter] public Guid? PatientId { get; set; }
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        try
        {
            var targets = await TargetsClient.GetAsync();
            saltTargetEnabled = targets.SaltTargetEnabled;
        }
        catch { saltTargetEnabled = false; }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task SaveAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            var dto = new UpsertActionsDto
            {
                Day = DateOnly.FromDateTime(DateTime.Now),
                FluidMl = form.FluidMl,
                ElectrolyteTaken = form.ElectrolyteTaken,
                MorningWaterBeforeStanding = form.MorningWaterBeforeStanding,
                UrineColor = string.IsNullOrEmpty(form.UrineColor) ? null : form.UrineColor,
                SaltTargetReached = saltTargetEnabled ? form.SaltTargetReached : null,
                RegularMeals = form.RegularMeals,
                SkippedBreakfast = form.SkippedBreakfast,
                SmallFrequentMeals = form.SmallFrequentMeals,
                AvoidedLargeHighCarbMeal = form.AvoidedLargeHighCarbMeal,
                AdequateProtein = form.AdequateProtein,
                AlcoholAvoided = form.AlcoholAvoided,
                CaffeineLevel = form.CaffeineLevel,
                CompressionSocks = form.CompressionSocks,
                WaistHighCompression = form.WaistHighCompression,
                AbdominalCompression = form.AbdominalCompression,
                CompressionHoursWorn = form.CompressionHoursWorn,
                RecumbentExercise = form.RecumbentExercise,
                Walking = form.Walking,
                Strength = form.Strength,
                Stretching = form.Stretching,
                PtExercises = form.PtExercises,
                ExerciseDurationMinutes = form.ExerciseDurationMinutes,
                ExerciseIntensity = string.IsNullOrWhiteSpace(form.ExerciseIntensity) ? null : form.ExerciseIntensity,
                PostExerciseSymptoms = string.IsNullOrWhiteSpace(form.PostExerciseSymptoms) ? null : form.PostExerciseSymptoms,
                PlannedRestBreaks = form.PlannedRestBreaks,
                AvoidedOverexertion = form.AvoidedOverexertion,
                UsedActivityPacing = form.UsedActivityPacing,
                AvoidedLongStanding = form.AvoidedLongStanding,
                SatDuringShowerCooking = form.SatDuringShowerCooking,
                MobilityAid = string.IsNullOrWhiteSpace(form.MobilityAid) ? null : form.MobilityAid,
                AvoidedHeat = form.AvoidedHeat,
                UsedCoolingVestFan = form.UsedCoolingVestFan,
                ColdShower = form.ColdShower,
                AvoidedHotBathSauna = form.AvoidedHotBathSauna,
                StayedInShadeAc = form.StayedInShadeAc,
                SleptEnough = form.SleptEnough,
                SleepQuality = form.SleepQuality,
                ConsistentBedtimes = form.ConsistentBedtimes,
                NapTaken = form.NapTaken,
                WokeRefreshed = wokeRefreshedYes,
                MedicationTakenAsPrescribed = form.MedicationTakenAsPrescribed,
                MissedDose = form.MissedDose,
                SideEffects = string.IsNullOrWhiteSpace(form.SideEffects) ? null : form.SideEffects,
                NewMedicationOrSupplement = string.IsNullOrWhiteSpace(form.NewMedicationOrSupplement) ? null : form.NewMedicationOrSupplement,
                RescueMedicationUsed = rescueMedYes,
            };
            if (PatientId.HasValue) await SharedPatients.UpsertActionsAsync(PatientId.Value, dto);
            else await ActionClient.UpsertAsync(dto);
            saved = true;
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("common.saveError");
        }
        finally { busy = false; }
    }

    // Localized day-of-month label per current language. Mirrors the helper
    // used in Profile.razor; English uses "Month Day", FR/ES use "Day Month".
    private string FormatToday()
    {
        var d = DateTime.Now;
        var months = Lang.Current switch
        {
            "fr" => new[] { "janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre" },
            "en" => new[] { "January","February","March","April","May","June","July","August","September","October","November","December" },
            _    => new[] { "enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre" },
        };
        return Lang.Current == "en" ? $"{months[d.Month - 1]} {d.Day}" : $"{d.Day} {(Lang.Current == "fr" ? "" : "de ")}{months[d.Month - 1]}";
    }

    private sealed class ActionsForm
    {
        public int? FluidMl { get; set; }
        public bool ElectrolyteTaken { get; set; }
        public bool MorningWaterBeforeStanding { get; set; }
        public string UrineColor { get; set; } = "";

        public bool? SaltTargetReached { get; set; }

        public bool RegularMeals { get; set; }
        public bool SkippedBreakfast { get; set; }
        public bool SmallFrequentMeals { get; set; }
        public bool AvoidedLargeHighCarbMeal { get; set; }
        public bool AdequateProtein { get; set; }
        public bool AlcoholAvoided { get; set; }
        public string CaffeineLevel { get; set; } = "None";

        public bool CompressionSocks { get; set; }
        public bool WaistHighCompression { get; set; }
        public bool AbdominalCompression { get; set; }
        public int? CompressionHoursWorn { get; set; }

        public bool RecumbentExercise { get; set; }
        public bool Walking { get; set; }
        public bool Strength { get; set; }
        public bool Stretching { get; set; }
        public bool PtExercises { get; set; }
        public int? ExerciseDurationMinutes { get; set; }
        public string ExerciseIntensity { get; set; } = "";
        public string PostExerciseSymptoms { get; set; } = "";

        public bool PlannedRestBreaks { get; set; }
        public bool AvoidedOverexertion { get; set; }
        public bool UsedActivityPacing { get; set; }
        public bool AvoidedLongStanding { get; set; }
        public bool SatDuringShowerCooking { get; set; }
        public string MobilityAid { get; set; } = "";

        public bool AvoidedHeat { get; set; }
        public bool UsedCoolingVestFan { get; set; }
        public bool ColdShower { get; set; }
        public bool AvoidedHotBathSauna { get; set; }
        public bool StayedInShadeAc { get; set; }

        public bool SleptEnough { get; set; }
        public int? SleepQuality { get; set; }
        public bool ConsistentBedtimes { get; set; }
        public bool NapTaken { get; set; }

        public bool MedicationTakenAsPrescribed { get; set; }
        public bool MissedDose { get; set; }
        public string SideEffects { get; set; } = "";
        public string NewMedicationOrSupplement { get; set; } = "";
    }
}
