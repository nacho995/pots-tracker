@page "/episode/new"
@inject AuthClient Auth
@inject EpisodeClient EpisodeClient
@inject NavigationManager Nav

<PageTitle>Episodio — POTS</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">Episode log · @FormatToday()</p>

    @if (saved is null)
    {
        <h1><span class="accent-rule"></span>Cuéntanos<br />qué pasó.</h1>
        <p class="lead">
            Solo lo que recuerdes. Mejor algo incompleto que nada;
            puedes editarlo después.
        </p>

        <EmergencyTriage />

        <EditForm Model="this" OnValidSubmit="SaveAsync" class="flow">
            <section class="card flow">
                <p class="card__label">Cuándo y cuánto</p>

                <label for="start-time">Empezó alrededor de</label>
                <input id="start-time" type="datetime-local" @bind="startTimeLocal" />

                <label for="duration">Duración (minutos, aproximado)</label>
                <input id="duration" type="number" min="0" max="1440" @bind="durationMinutes" />
            </section>

            <section class="card flow">
                <p class="card__label">Cómo se sintió</p>

                <label for="main-symptom">Síntoma principal</label>
                <input id="main-symptom" type="text" @bind="mainSymptom"
                       placeholder="Mareo, palpitaciones, casi-desmayo..." maxlength="200" />

                <label for="posture">Postura justo antes</label>
                <select id="posture" @bind="postureBefore" class="text-input">
                    <option value="">— sin especificar —</option>
                    <option value="Lying">Tumbada</option>
                    <option value="Sitting">Sentada</option>
                    <option value="Standing">De pie</option>
                    <option value="Walking">Caminando</option>
                    <option value="Shower">En la ducha</option>
                    <option value="AfterMeal">Después de comer</option>
                </select>

                <label for="trigger">Lo que sospechas que lo provocó</label>
                <select id="trigger" @bind="triggerSuspected" class="text-input">
                    <option value="Unknown">No estoy segura</option>
                    <option value="Heat">Calor</option>
                    <option value="Dehydration">Deshidratación</option>
                    <option value="MissedMeal">Saltarme una comida</option>
                    <option value="Menstrual">Menstruación</option>
                    <option value="Stress">Estrés</option>
                    <option value="PoorSleep">Mal sueño</option>
                    <option value="Exercise">Ejercicio</option>
                    <option value="Infection">Infección</option>
                    <option value="LongStanding">Mucho rato de pie</option>
                    <option value="Alcohol">Alcohol</option>
                    <option value="LargeMeal">Comida muy grande</option>
                </select>
            </section>

            <section class="card flow">
                <p class="card__label">Mediciones durante (opcional)</p>

                <label for="hr">Frecuencia cardíaca (lpm)</label>
                <input id="hr" type="number" min="20" max="250" @bind="hrDuringBpm" />

                <label for="bp">Tensión arterial (sistólica / diastólica)</label>
                <div class="bp-row">
                    <input type="number" min="50" max="250" @bind="bpSys" placeholder="120" aria-label="Sistólica" />
                    <span class="bp-row__sep" aria-hidden="true">/</span>
                    <input type="number" min="30" max="180" @bind="bpDia" placeholder="80" aria-label="Diastólica" />
                </div>
            </section>

            <section class="card flow">
                <p class="card__label">Qué hiciste</p>

                <label for="action-taken">Acción tomada</label>
                <input id="action-taken" type="text" @bind="actionTaken"
                       placeholder="Me tumbé, levanté piernas, bebí agua..." maxlength="500" />

                <label for="recovery">Tiempo hasta sentirte mejor (minutos)</label>
                <input id="recovery" type="number" min="0" max="1440" @bind="recoveryMinutes" />

                <label class="checkbox-row">
                    <input type="checkbox" @bind="preventedFainting" />
                    <span>Evité desmayarme gracias a alguna maniobra.</span>
                </label>
            </section>

            <section class="card flow">
                <p class="card__label">Nota libre</p>
                <textarea @bind="note" rows="3" maxlength="1000"
                          class="text-input"
                          placeholder="Cualquier cosa que quieras recordar."></textarea>
            </section>

            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }

            <div class="action-row">
                <button type="submit" class="btn--primary" disabled="@busy">
                    <span>@(busy ? "Guardando..." : "Guardar episodio")</span>
                    <span class="arrow" aria-hidden="true">→</span>
                </button>
                <a href="/today" class="btn--ghost" style="text-decoration:none;text-align:center;line-height:1.2;display:inline-flex;align-items:center;justify-content:center;">
                    Cancelar
                </a>
            </div>
        </EditForm>
    }
    else
    {
        <p class="eyebrow">Episodio · @FormatTime(saved.CreatedAt)</p>
        <h1><span class="accent-rule"></span>Guardado.</h1>
        <p class="lead">
            Cuando hables con tu médico, lo tendrás aquí. Ya puedes descansar.
        </p>

        <EmergencyTriage />

        <hr class="divider divider--ornament" aria-hidden="true" />

        <div class="action-row">
            <a href="/today" class="btn--primary" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5em;text-decoration:none;">
                <span>Volver a hoy</span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>
        </div>
    }
</div>

@code {
    private static readonly string[] MonthsEs =
    {
        "enero", "febrero", "marzo", "abril", "mayo", "junio",
        "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"
    };

    private DateTime startTimeLocal = DateTime.Now;
    private int? durationMinutes;
    private string mainSymptom = "";
    private string postureBefore = "";
    private string triggerSuspected = "Unknown";
    private int? hrDuringBpm;
    private int? bpSys;
    private int? bpDia;
    private string actionTaken = "";
    private int? recoveryMinutes;
    private bool preventedFainting;
    private string note = "";

    private bool busy = false;
    private string? errorMessage;
    private EpisodeDto? saved;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }

    private async Task SaveAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            var dto = new CreateEpisodeDto(
                StartTime: new DateTimeOffset(startTimeLocal, TimeZoneInfo.Local.GetUtcOffset(startTimeLocal)),
                DurationMinutes: durationMinutes,
                MainSymptom: string.IsNullOrWhiteSpace(mainSymptom) ? null : mainSymptom,
                PostureBefore: string.IsNullOrWhiteSpace(postureBefore) ? null : postureBefore,
                TriggerSuspected: triggerSuspected,
                HrDuringBpm: hrDuringBpm,
                BpDuringSystolic: bpSys,
                BpDuringDiastolic: bpDia,
                ActionTaken: string.IsNullOrWhiteSpace(actionTaken) ? null : actionTaken,
                RecoveryTimeMinutes: recoveryMinutes,
                PreventedFainting: preventedFainting,
                Note: string.IsNullOrWhiteSpace(note) ? null : note);
            saved = await EpisodeClient.CreateAsync(dto);
        }
        catch (HttpRequestException)
        {
            errorMessage = "No se ha podido guardar el episodio. Inténtalo de nuevo.";
        }
        finally
        {
            busy = false;
        }
    }

    private static string FormatToday()
    {
        var d = DateTime.Now;
        return $"{d.Day} de {MonthsEs[d.Month - 1]}";
    }

    private static string FormatTime(DateTimeOffset dt) =>
        dt.ToLocalTime().ToString("HH:mm");
}
