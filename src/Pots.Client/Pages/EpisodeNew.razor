@page "/episode/new"
@page "/shared/{PatientId:guid}/episode/new"
@inject AuthClient Auth
@inject EpisodeClient EpisodeClient
@inject SharedPatientClient SharedPatients
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("episode.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("episode.eyebrow") · @FormatToday()</p>

    @if (saved is null)
    {
        <h1><span class="accent-rule"></span>@((MarkupString)Lang.T("episode.title"))</h1>
        <p class="lead">@Lang.T("episode.lead")</p>

        <EmergencyTriage />

        <EditForm Model="this" OnValidSubmit="SaveAsync" class="flow">
            <section class="card flow">
                <p class="card__label">@Lang.T("episode.when.label")</p>

                <label for="start-time">@Lang.T("episode.startTime")</label>
                <input id="start-time" type="datetime-local" @bind="startTimeLocal" />

                <label for="duration">@Lang.T("episode.duration")</label>
                <input id="duration" type="number" min="0" max="1440" @bind="durationMinutes" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("episode.how.label")</p>

                <label for="main-symptom">@Lang.T("episode.mainSymptom")</label>
                <input id="main-symptom" type="text" @bind="mainSymptom"
                       placeholder="@Lang.T("episode.mainSymptom.placeholder")" maxlength="200" />

                <label for="posture">@Lang.T("episode.postureBefore")</label>
                <select id="posture" @bind="postureBefore" class="text-input">
                    <option value="">@Lang.T("common.unspecified")</option>
                    <option value="Lying">@Lang.T("posture.lying")</option>
                    <option value="Sitting">@Lang.T("posture.sitting")</option>
                    <option value="Standing">@Lang.T("posture.standing")</option>
                    <option value="Walking">@Lang.T("posture.walking")</option>
                    <option value="Shower">@Lang.T("posture.shower")</option>
                    <option value="AfterMeal">@Lang.T("posture.afterMeal")</option>
                </select>

                <label for="trigger">@Lang.T("episode.trigger")</label>
                <select id="trigger" @bind="triggerSuspected" class="text-input">
                    <option value="Unknown">@Lang.T("trigger.unknown")</option>
                    <option value="Heat">@Lang.T("trigger.heat")</option>
                    <option value="Dehydration">@Lang.T("trigger.dehydration")</option>
                    <option value="MissedMeal">@Lang.T("trigger.missedMeal")</option>
                    <option value="Menstrual">@Lang.T("trigger.menstrual")</option>
                    <option value="Stress">@Lang.T("trigger.stress")</option>
                    <option value="PoorSleep">@Lang.T("trigger.poorSleep")</option>
                    <option value="Exercise">@Lang.T("trigger.exercise")</option>
                    <option value="Infection">@Lang.T("trigger.infection")</option>
                    <option value="LongStanding">@Lang.T("trigger.longStanding")</option>
                    <option value="Alcohol">@Lang.T("trigger.alcohol")</option>
                    <option value="LargeMeal">@Lang.T("trigger.largeMeal")</option>
                </select>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("episode.measure.label")</p>

                <label for="hr">@Lang.T("episode.hr")</label>
                <input id="hr" type="number" min="20" max="250" @bind="hrDuringBpm" />

                <label for="bp">@Lang.T("episode.bp")</label>
                <div class="bp-row">
                    <input type="number" min="50" max="250" @bind="bpSys" placeholder="120" aria-label="@Lang.T("episode.bp.sys")" />
                    <span class="bp-row__sep" aria-hidden="true">/</span>
                    <input type="number" min="30" max="180" @bind="bpDia" placeholder="80" aria-label="@Lang.T("episode.bp.dia")" />
                </div>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("episode.action.label")</p>

                <label for="action-taken">@Lang.T("episode.action.taken")</label>
                <input id="action-taken" type="text" @bind="actionTaken"
                       placeholder="@Lang.T("episode.action.placeholder")" maxlength="500" />

                <label for="recovery">@Lang.T("episode.recovery")</label>
                <input id="recovery" type="number" min="0" max="1440" @bind="recoveryMinutes" />

                <label class="checkbox-row">
                    <input type="checkbox" @bind="preventedFainting" />
                    <span>@Lang.T("episode.preventedFainting")</span>
                </label>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("episode.note.label")</p>
                <textarea @bind="note" rows="3" maxlength="1000"
                          class="text-input"
                          placeholder="@Lang.T("episode.note.placeholder")"></textarea>
            </section>

            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }

            <div class="action-row">
                <button type="submit" class="btn--primary" disabled="@busy">
                    <span>@(busy ? Lang.T("saving") : Lang.T("episode.saveBtn"))</span>
                    <span class="arrow" aria-hidden="true">→</span>
                </button>
                <a href="/today" class="btn--ghost" style="text-decoration:none;text-align:center;line-height:1.2;display:inline-flex;align-items:center;justify-content:center;">
                    @Lang.T("cancel")
                </a>
            </div>
        </EditForm>
    }
    else
    {
        <p class="eyebrow">@Lang.T("episode.saved.eyebrow") · @FormatTime(saved.CreatedAt)</p>
        <h1><span class="accent-rule"></span>@Lang.T("episode.saved.title")</h1>
        <p class="lead">@Lang.T("episode.saved.lead")</p>

        <EmergencyTriage />

        <hr class="divider divider--ornament" aria-hidden="true" />

        <div class="action-row">
            <a href="/today" class="btn--primary" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5em;text-decoration:none;">
                <span>@Lang.T("common.backToToday")</span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>
        </div>
    }
</div>

@code {
    private DateTime startTimeLocal = DateTime.Now;
    private int? durationMinutes;
    private string mainSymptom = "";
    private string postureBefore = "";
    private string triggerSuspected = "Unknown";
    private int? hrDuringBpm;
    private int? bpSys;
    private int? bpDia;
    private string actionTaken = "";
    private int? recoveryMinutes;
    private bool preventedFainting;
    private string note = "";

    private bool busy = false;
    private string? errorMessage;
    private EpisodeDto? saved;

    [Parameter] public Guid? PatientId { get; set; }

    protected override void OnInitialized()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task SaveAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            var dto = new CreateEpisodeDto(
                StartTime: new DateTimeOffset(startTimeLocal, TimeZoneInfo.Local.GetUtcOffset(startTimeLocal)),
                DurationMinutes: durationMinutes,
                MainSymptom: string.IsNullOrWhiteSpace(mainSymptom) ? null : mainSymptom,
                PostureBefore: string.IsNullOrWhiteSpace(postureBefore) ? null : postureBefore,
                TriggerSuspected: triggerSuspected,
                HrDuringBpm: hrDuringBpm,
                BpDuringSystolic: bpSys,
                BpDuringDiastolic: bpDia,
                ActionTaken: string.IsNullOrWhiteSpace(actionTaken) ? null : actionTaken,
                RecoveryTimeMinutes: recoveryMinutes,
                PreventedFainting: preventedFainting,
                Note: string.IsNullOrWhiteSpace(note) ? null : note);
            saved = PatientId.HasValue
                ? await SharedPatients.CreateEpisodeAsync(PatientId.Value, dto)
                : await EpisodeClient.CreateAsync(dto);
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("episode.saveError");
        }
        finally
        {
            busy = false;
        }
    }

    private string FormatToday()
    {
        var d = DateTime.Now;
        var months = Lang.Current switch
        {
            "fr" => new[] { "janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre" },
            "en" => new[] { "January","February","March","April","May","June","July","August","September","October","November","December" },
            _    => new[] { "enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre" },
        };
        return Lang.Current == "en" ? $"{months[d.Month - 1]} {d.Day}" : $"{d.Day} {(Lang.Current == "fr" ? "" : "de ")}{months[d.Month - 1]}";
    }

    private static string FormatTime(DateTimeOffset dt) =>
        dt.ToLocalTime().ToString("HH:mm");
}
