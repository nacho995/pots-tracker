@page "/today"
@inject AuthClient Auth
@inject PatientClient PatientClient
@inject StatusClient StatusClient
@inject RoleContextService Roles
@inject LanguageService Lang
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@Lang.T("nav.today") — POTS</PageTitle>

<div class="shell flow stagger">
    @if (loading)
    {
        <p class="eyebrow">@Lang.T("today.loading")</p>
        <h1><span class="accent-rule"></span>@Lang.T("today.moment")</h1>
    }
    else if (patient is null)
    {
        @* OnInitializedAsync redirects to /shared or /welcome before this
           branch matters; kept as a safety net so a null patient cannot fall
           through to the main UI, which assumes patient is non-null.
           The h1 is screen-reader-only because the redirect is near-instant
           and a visible heading would flash; landmark navigation still works
           for assistive tech. *@
        <h1 class="visually-hidden">@Lang.T("common.redirecting")</h1>
        <p class="eyebrow">@Lang.T("common.redirecting")</p>
    }
    else if (justRecorded is { } recorded)
    {
        <p class="eyebrow">
            @Lang.T("today.recorded") · @FormatTime(recorded.CreatedAt)
            @if (!string.IsNullOrEmpty(recorded.RecorderName))
            {
                <span> · @string.Format(Lang.T("status.recordedBy"), recorded.RecorderName)</span>
            }
        </p>
        <h1><span class="accent-rule"></span>@ConfirmTitle(recorded.Status)</h1>
        <p class="lead">@ConfirmHint(recorded.Status)</p>

        @if (recorded.Status == "Red")
        {
            <a href="/episode/new" class="btn--primary" style="display:inline-flex;width:auto;">
                <span>@Lang.T("today.addEpisode")</span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>
        }
        else if (recorded.Status == "Orange")
        {
            <a href="/log/symptoms" class="btn--link">@Lang.T("today.addSymptoms")</a>
        }

        @if (showDetail)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("today.detail.title")</p>

                <label for="d-posture">@Lang.T("today.detail.posture")</label>
                <select id="d-posture" class="text-input" @bind="detailPosture">
                    <option value="">@Lang.T("common.unspecified")</option>
                    <option value="Lying">@Lang.T("posture.lying")</option>
                    <option value="Sitting">@Lang.T("posture.sitting")</option>
                    <option value="Standing">@Lang.T("posture.standing")</option>
                    <option value="Walking">@Lang.T("posture.walking")</option>
                    <option value="Shower">@Lang.T("posture.shower")</option>
                    <option value="AfterMeal">@Lang.T("posture.afterMeal")</option>
                </select>

                <label for="d-activity">@Lang.T("today.detail.activity")</label>
                <input id="d-activity" type="text" maxlength="100" @bind="detailActivity"
                       placeholder="@Lang.T("today.detail.activity.placeholder")" />

                <label for="d-location">@Lang.T("today.detail.location")</label>
                <input id="d-location" type="text" maxlength="200" @bind="detailLocation"
                       placeholder="@Lang.T("today.detail.location.placeholder")" />

                <label for="d-note">@Lang.T("today.detail.note")</label>
                <textarea id="d-note" class="text-input" rows="3" maxlength="1000"
                          @bind="detailNote"
                          placeholder="@Lang.T("today.detail.note.placeholder")"></textarea>

                @if (detailError is not null)
                {
                    <p class="error-text" role="alert">@detailError</p>
                }

                <div class="action-row">
                    <button class="btn--primary" @onclick="SaveDetailAsync" disabled="@detailBusy">
                        <span>@(detailBusy ? Lang.T("saving") : Lang.T("today.detail.save"))</span>
                        <span class="arrow" aria-hidden="true">→</span>
                    </button>
                    <button type="button" class="btn--ghost" @onclick="CancelDetail" disabled="@detailBusy">
                        @Lang.T("cancel")
                    </button>
                </div>
            </section>
        }
        else if (HasDetail(recorded))
        {
            <section class="card card--sunk">
                <p class="card__label">@Lang.T("today.detail.saved")</p>
                @if (recorded.Posture is not null) { <p>@Lang.T("today.detail.row.posture") <strong>@PostureLabel(recorded.Posture)</strong></p> }
                @if (!string.IsNullOrEmpty(recorded.Activity)) { <p>@Lang.T("today.detail.row.doing") @recorded.Activity</p> }
                @if (!string.IsNullOrEmpty(recorded.LocationNote)) { <p>@Lang.T("today.detail.row.place") @recorded.LocationNote</p> }
                @if (!string.IsNullOrEmpty(recorded.Note)) { <p>@Lang.T("today.detail.row.note") @recorded.Note</p> }
            </section>
        }
        else
        {
            <hr class="divider" aria-hidden="true" />
            <p class="muted">@Lang.T("today.detail.suggest")</p>
            <button class="btn--ghost" @onclick="OpenDetail">@Lang.T("today.detail.add")</button>
        }

        <hr class="divider" aria-hidden="true" />

        <p class="card__label">@Lang.T("today.switch.label")</p>
        <div class="status-switch">
            <button type="button"
                    class="status-switch__pill status-switch__pill--green @(recorded.Status == "Green" ? "is-current" : "")"
                    @onclick="@(() => SwitchStatusAsync("Green"))"
                    disabled="@(undoBusy || recorded.Status == "Green")">
                <span class="status-switch__dot"></span>
                <span>@Lang.T("today.green")</span>
            </button>
            <button type="button"
                    class="status-switch__pill status-switch__pill--orange @(recorded.Status == "Orange" ? "is-current" : "")"
                    @onclick="@(() => SwitchStatusAsync("Orange"))"
                    disabled="@(undoBusy || recorded.Status == "Orange")">
                <span class="status-switch__dot"></span>
                <span>@Lang.T("today.orange")</span>
            </button>
            <button type="button"
                    class="status-switch__pill status-switch__pill--red @(recorded.Status == "Red" ? "is-current" : "")"
                    @onclick="@(() => SwitchStatusAsync("Red"))"
                    disabled="@(undoBusy || recorded.Status == "Red")">
                <span class="status-switch__dot"></span>
                <span>@Lang.T("today.red")</span>
            </button>
        </div>
        <p class="muted">@Lang.T("today.switch.hint")</p>

        @if (undoError is not null)
        {
            <p class="error-text" role="alert">@undoError</p>
        }

        <hr class="divider divider--ornament" aria-hidden="true" />

        <button class="btn--ghost" @onclick="Reset">@Lang.T("today.again")</button>
    }
    else
    {
        <p class="eyebrow">@Lang.T("today.eyebrow") · @FormatToday()</p>
        <h1><span class="accent-rule"></span>@Lang.T("today.howAreYou")</h1>

        <div class="status-grid">
            <button class="status-btn status-btn--green" @onclick="RecordGreen" disabled="@busy">
                <span class="status-btn__chip" aria-hidden="true"></span>
                <span class="status-btn__label">@Lang.T("today.green")</span>
                <span class="status-btn__hint">@Lang.T("today.green.hint")</span>
            </button>
            <button class="status-btn status-btn--orange" @onclick="RecordOrange" disabled="@busy">
                <span class="status-btn__chip" aria-hidden="true"></span>
                <span class="status-btn__label">@Lang.T("today.orange")</span>
                <span class="status-btn__hint">@Lang.T("today.orange.hint")</span>
            </button>
            <button class="status-btn status-btn--red" @onclick="RecordRed" disabled="@busy">
                <span class="status-btn__chip" aria-hidden="true"></span>
                <span class="status-btn__label">@Lang.T("today.red")</span>
                <span class="status-btn__hint">@Lang.T("today.red.hint")</span>
            </button>
        </div>

        @if (errorMessage is not null)
        {
            <p class="error-text" role="alert">@errorMessage</p>
        }

        @if (todayHistory.Count > 0)
        {
            <hr class="divider" aria-hidden="true" />
            <p class="card__label">@Lang.T("today.history.label")</p>
            <ul class="status-history">
                @foreach (var h in todayHistory)
                {
                    <li class="status-history__item">
                        <button type="button"
                                class="status-history__row @(editingId == h.Id ? "is-editing" : "")"
                                @onclick="@(() => ToggleEdit(h.Id))"
                                aria-expanded="@(editingId == h.Id)">
                            <span class="status-dot status-dot--@(h.Status.ToLowerInvariant())"></span>
                            <span class="status-history__time tabular">@FormatTime(h.CreatedAt)</span>
                            <span class="status-history__label">
                                @StatusLabel(h.Status)
                                @if (!string.IsNullOrEmpty(h.RecorderName))
                                {
                                    <small class="status-history__by"> · @string.Format(Lang.T("status.recordedBy"), h.RecorderName)</small>
                                }
                            </span>
                            <span class="status-history__chev" aria-hidden="true">@(editingId == h.Id ? "▾" : "›")</span>
                        </button>
                        @if (editingId == h.Id)
                        {
                            <div class="status-history__edit">
                                <div class="status-switch">
                                    <button type="button"
                                            class="status-switch__pill status-switch__pill--green @(h.Status == "Green" ? "is-current" : "")"
                                            @onclick="@(() => EditHistoryAsync(h, "Green"))"
                                            disabled="@(historyBusy || h.Status == "Green")">
                                        <span class="status-switch__dot"></span>
                                        <span>@Lang.T("today.green")</span>
                                    </button>
                                    <button type="button"
                                            class="status-switch__pill status-switch__pill--orange @(h.Status == "Orange" ? "is-current" : "")"
                                            @onclick="@(() => EditHistoryAsync(h, "Orange"))"
                                            disabled="@(historyBusy || h.Status == "Orange")">
                                        <span class="status-switch__dot"></span>
                                        <span>@Lang.T("today.orange")</span>
                                    </button>
                                    <button type="button"
                                            class="status-switch__pill status-switch__pill--red @(h.Status == "Red" ? "is-current" : "")"
                                            @onclick="@(() => EditHistoryAsync(h, "Red"))"
                                            disabled="@(historyBusy || h.Status == "Red")">
                                        <span class="status-switch__dot"></span>
                                        <span>@Lang.T("today.red")</span>
                                    </button>
                                </div>
                                <div class="action-row">
                                    <button type="button" class="btn--quiet" @onclick="@(() => DeleteHistoryAsync(h))" disabled="@historyBusy">
                                        @(historyBusy ? "..." : Lang.T("today.history.delete"))
                                    </button>
                                    <button type="button" class="btn--quiet" @onclick="CloseEdit" disabled="@historyBusy">
                                        @Lang.T("today.history.close")
                                    </button>
                                </div>
                                @if (historyError is not null)
                                {
                                    <p class="error-text" role="alert">@historyError</p>
                                }
                            </div>
                        }
                    </li>
                }
            </ul>
        }
    }
</div>

@code {
    private PatientDto? patient;
    private bool loading = true;
    private bool busy = false;
    private string? errorMessage;
    private DailyStatusDto? justRecorded;
    private List<DailyStatusDto> todayHistory = new();

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            patient = await PatientClient.GetMyPatientAsync();
            if (patient is null)
            {
                // No own POTS profile: route to the appropriate landing
                // instead of prompting the user to register as a patient.
                // A caregiver invited by Amelia must never be asked
                // "how are your symptoms today?".
                try { await Roles.EnsureLoadedAsync(); }
                catch { /* fall through to /welcome — never trap the user */ }
                Nav.NavigateTo(Roles.HasSharedAccess ? "/shared" : "/welcome", replace: true);
                return;
            }
            todayHistory = await StatusClient.GetTodayAsync();
        }
        catch (HttpRequestException) { /* keep state */ }
        finally { loading = false; }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private Task RecordGreen()  => SelectAsync("Green");
    private Task RecordOrange() => SelectAsync("Orange");
    private Task RecordRed()    => SelectAsync("Red");

    private async Task SelectAsync(string status)
    {
        errorMessage = null;
        busy = true;
        try
        {
            var saved = await StatusClient.RecordAsync(
                new RecordStatusDto(status, EpisodeOccurred: status == "Red"));
            justRecorded = saved;
            todayHistory = await StatusClient.GetTodayAsync();
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("common.saveError");
        }
        finally { busy = false; }
    }

    private void Reset()
    {
        justRecorded = null;
        errorMessage = null;
        showDetail = false;
        detailPosture = "";
        detailActivity = "";
        detailLocation = "";
        detailNote = "";
        detailError = null;
    }

    private bool showDetail = false;
    private string detailPosture = "";
    private string detailActivity = "";
    private string detailLocation = "";
    private string detailNote = "";
    private bool detailBusy = false;
    private string? detailError = null;

    private void OpenDetail()
    {
        if (justRecorded is null) return;
        detailPosture = justRecorded.Posture ?? "";
        detailActivity = justRecorded.Activity ?? "";
        detailLocation = justRecorded.LocationNote ?? "";
        detailNote = justRecorded.Note ?? "";
        detailError = null;
        showDetail = true;
    }

    private void CancelDetail()
    {
        showDetail = false;
        detailError = null;
    }

    private bool undoBusy = false;
    private string? undoError = null;

    private async Task UndoAsync()
    {
        if (justRecorded is null) return;
        undoError = null;
        undoBusy = true;
        try
        {
            await StatusClient.DeleteAsync(justRecorded.Id);
            justRecorded = null;
            showDetail = false;
            detailError = null;
            todayHistory = await StatusClient.GetTodayAsync();
        }
        catch (HttpRequestException)
        {
            undoError = Lang.T("common.saveError");
        }
        finally { undoBusy = false; }
    }

    // Swap the current status for a different one. Implemented as DELETE+POST
    // so the timeline reflects the corrected state without retaining the
    // misclick in the patient's history. The deletion is audited.
    private async Task SwitchStatusAsync(string newStatus)
    {
        if (justRecorded is null || justRecorded.Status == newStatus) return;
        undoError = null;
        undoBusy = true;
        try
        {
            await StatusClient.DeleteAsync(justRecorded.Id);
            justRecorded = await StatusClient.RecordAsync(
                new RecordStatusDto(newStatus, EpisodeOccurred: newStatus == "Red"));
            todayHistory = await StatusClient.GetTodayAsync();
        }
        catch (HttpRequestException)
        {
            undoError = Lang.T("common.saveError");
        }
        finally { undoBusy = false; }
    }

    private Guid? editingId;
    private bool historyBusy = false;
    private string? historyError = null;

    private void ToggleEdit(Guid id)
    {
        historyError = null;
        editingId = editingId == id ? null : id;
    }

    private void CloseEdit()
    {
        editingId = null;
        historyError = null;
    }

    private async Task EditHistoryAsync(DailyStatusDto current, string newStatus)
    {
        if (current.Status == newStatus) return;
        historyError = null;
        historyBusy = true;
        try
        {
            await StatusClient.DeleteAsync(current.Id);
            await StatusClient.RecordAsync(
                new RecordStatusDto(newStatus, EpisodeOccurred: newStatus == "Red"));
            todayHistory = await StatusClient.GetTodayAsync();
            if (justRecorded?.Id == current.Id) justRecorded = null;
            editingId = null;
        }
        catch (HttpRequestException)
        {
            historyError = Lang.T("common.saveError");
        }
        finally { historyBusy = false; }
    }

    private async Task DeleteHistoryAsync(DailyStatusDto current)
    {
        historyError = null;
        historyBusy = true;
        try
        {
            await StatusClient.DeleteAsync(current.Id);
            todayHistory = await StatusClient.GetTodayAsync();
            if (justRecorded?.Id == current.Id) justRecorded = null;
            editingId = null;
        }
        catch (HttpRequestException)
        {
            historyError = Lang.T("common.saveError");
        }
        finally { historyBusy = false; }
    }

    private async Task SaveDetailAsync()
    {
        if (justRecorded is null) return;
        detailError = null;
        detailBusy = true;
        try
        {
            var dto = new UpdateStatusDetailDto(
                Posture: string.IsNullOrWhiteSpace(detailPosture) ? null : detailPosture,
                Activity: string.IsNullOrWhiteSpace(detailActivity) ? null : detailActivity,
                LocationNote: string.IsNullOrWhiteSpace(detailLocation) ? null : detailLocation,
                Note: string.IsNullOrWhiteSpace(detailNote) ? null : detailNote,
                EpisodeOccurred: justRecorded.EpisodeOccurred);
            justRecorded = await StatusClient.UpdateDetailAsync(justRecorded.Id, dto);
            showDetail = false;
            todayHistory = await StatusClient.GetTodayAsync();
        }
        catch (HttpRequestException)
        {
            detailError = Lang.T("common.saveError");
        }
        finally { detailBusy = false; }
    }

    private static bool HasDetail(DailyStatusDto d) =>
        d.Posture is not null
        || !string.IsNullOrEmpty(d.Activity)
        || !string.IsNullOrEmpty(d.LocationNote)
        || !string.IsNullOrEmpty(d.Note);

    // Localized posture label. Falls back to the raw enum string if no key
    // matches (defensive: backend may add new enum members before the
    // translations land).
    private string PostureLabel(string? p) => p switch
    {
        "Lying" => Lang.T("posture.lying"),
        "Sitting" => Lang.T("posture.sitting"),
        "Standing" => Lang.T("posture.standing"),
        "Walking" => Lang.T("posture.walking"),
        "Shower" => Lang.T("posture.shower"),
        "AfterMeal" => Lang.T("posture.afterMeal"),
        _ => p ?? ""
    };

    private string FormatToday()
    {
        var d = DateTime.Now;
        var months = Lang.Current switch
        {
            "fr" => new[] { "janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre" },
            "en" => new[] { "January","February","March","April","May","June","July","August","September","October","November","December" },
            _    => new[] { "enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre" },
        };
        return Lang.Current == "en" ? $"{months[d.Month - 1]} {d.Day}" : $"{d.Day} {(Lang.Current == "fr" ? "" : "de ")}{months[d.Month - 1]}";
    }

    private static string FormatTime(DateTimeOffset dt) =>
        dt.ToLocalTime().ToString("HH:mm");

    private string StatusLabel(string status) => status switch
    {
        "Green"  => Lang.T("status.green"),
        "Orange" => Lang.T("status.orange"),
        "Red"    => Lang.T("status.red"),
        _        => status
    };

    private string ConfirmTitle(string status) => status switch
    {
        "Green"  => Lang.T("today.confirm.title.good"),
        "Orange" => Lang.T("today.confirm.title.warn"),
        "Red"    => Lang.T("today.confirm.title.bad"),
        _        => Lang.T("today.confirm.title.good")
    };

    private string ConfirmHint(string status) => status switch
    {
        "Green"  => Lang.T("today.confirm.hint.good"),
        "Orange" => Lang.T("today.confirm.hint.warn"),
        "Red"    => Lang.T("today.confirm.hint.bad"),
        _        => ""
    };
}
