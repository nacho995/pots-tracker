@page "/trends"
@inject AuthClient Auth
@inject TrendsClient TrendsClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("trends.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@string.Format(Lang.T("trends.eyebrow.range"), days)</p>
    <h1><span class="accent-rule"></span>@Lang.T("trends.title")</h1>
    <p class="lead">
        @Lang.T("trends.lead.before")<em>@Lang.T("trends.lead.em")</em>@Lang.T("trends.lead.after")
    </p>

    <div class="range-selector">
        <button class="@(days == 7 ? "active" : "")" @onclick="() => Reload(7)">7 @Lang.T("trends.range.d")</button>
        <button class="@(days == 30 ? "active" : "")" @onclick="() => Reload(30)">30 @Lang.T("trends.range.d")</button>
        <button class="@(days == 90 ? "active" : "")" @onclick="() => Reload(90)">90 @Lang.T("trends.range.d")</button>
    </div>

    @if (loading)
    {
        <p>@Lang.T("loading")...</p>
    }
    else if (trends is null)
    {
        <p class="muted">@Lang.T("trends.empty")</p>
    }
    else
    {
        <section class="card flow">
            <p class="card__label">@Lang.T("trends.distribution")</p>
            <div class="status-totals">
                <div class="status-total status-total--green">
                    <span class="status-total__num tabular">@trends.GreenCount</span>
                    <span class="status-total__label">@Lang.T("status.green")</span>
                </div>
                <div class="status-total status-total--orange">
                    <span class="status-total__num tabular">@trends.OrangeCount</span>
                    <span class="status-total__label">@Lang.T("status.orange")</span>
                </div>
                <div class="status-total status-total--red">
                    <span class="status-total__num tabular">@trends.RedCount</span>
                    <span class="status-total__label">@Lang.T("status.red")</span>
                </div>
            </div>
        </section>

        <section class="card flow">
            <p class="card__label">@string.Format(Lang.T("trends.episodes.label"), trends.EpisodeCount, trends.RangeDays)</p>
            @if (trends.EpisodesPerWeek.Count == 0)
            {
                <p class="muted">@Lang.T("trends.episodes.none")</p>
            }
            else
            {
                <ul class="bar-list">
                    @foreach (var w in trends.EpisodesPerWeek)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label tabular">@w.WeekStart</span>
                            <span class="bar-row__bar"
                                  style="--w: @(MaxWeek(trends) == 0 ? 0 : (int)(100.0 * w.Count / MaxWeek(trends)))%">
                            </span>
                            <span class="bar-row__count tabular">@w.Count</span>
                        </li>
                    }
                </ul>
            }
        </section>

        @if (trends.TopTriggers.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.triggers.label")</p>
                <ul class="bar-list">
                    @foreach (var t in trends.TopTriggers)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@TriggerLabel(t.Trigger)</span>
                            <span class="bar-row__bar"
                                  style="--w: @(MaxTrigger(trends) == 0 ? 0 : (int)(100.0 * t.Count / MaxTrigger(trends)))%">
                            </span>
                            <span class="bar-row__count tabular">@t.Count</span>
                        </li>
                    }
                </ul>
                <p class="muted">
                    @Lang.T("trends.triggers.disclaimer.before")<em>@Lang.T("trends.triggers.disclaimer.em")</em>@Lang.T("trends.triggers.disclaimer.after")
                </p>
            </section>
        }

        <section class="card flow">
            <p class="card__label">@Lang.T("trends.burden.label")</p>
            <ul class="avg-list">
                <li>@Lang.T("trends.burden.fatigue") · <strong class="tabular">@FmtAvg(trends.AvgFatigue)</strong></li>
                <li>@Lang.T("trends.burden.brainFog") · <strong class="tabular">@FmtAvg(trends.AvgBrainFog)</strong></li>
                <li>@Lang.T("trends.burden.dizziness") · <strong class="tabular">@FmtAvg(trends.AvgDizziness)</strong></li>
            </ul>
            <p class="muted">@Lang.T("trends.burden.note")</p>
        </section>

        @if (trends.BestWorst is { } bw)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.bestWorst.label")</p>
                <div class="best-worst">
                    <div class="best-worst__cell">
                        <p class="best-worst__label">@Lang.T("trends.bestWorst.best")</p>
                        <p class="best-worst__day">@(bw.BestDay ?? "—")</p>
                        <p class="muted">@bw.BestGreen @Lang.T("trends.bestWorst.greens") · @bw.BestRed @Lang.T("trends.bestWorst.reds")</p>
                    </div>
                    <div class="best-worst__cell">
                        <p class="best-worst__label">@Lang.T("trends.bestWorst.worst")</p>
                        <p class="best-worst__day">@(bw.WorstDay ?? "—")</p>
                        <p class="muted">@bw.WorstRed @Lang.T("trends.bestWorst.reds") · @bw.WorstGreen @Lang.T("trends.bestWorst.greens")</p>
                    </div>
                </div>
            </section>
        }

        @if (trends.SleepQualityVsSymptoms.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.sleep.label")</p>
                <ul class="bar-list">
                    @foreach (var r in trends.SleepQualityVsSymptoms)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@PrettyBucket(r.Bucket)</span>
                            <span class="bar-row__bar"
                                  style="--w: @(MaxAssoc(trends.SleepQualityVsSymptoms) == 0 ? 0 : (int)(100.0 * (r.AvgSymptomBurden ?? 0) / 10))%">
                            </span>
                            <span class="bar-row__count tabular">@FmtAvg(r.AvgSymptomBurden) (@r.DayCount d)</span>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (trends.HydrationVsSymptoms.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.hydration.label")</p>
                <ul class="bar-list">
                    @foreach (var r in trends.HydrationVsSymptoms)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@PrettyBucket(r.Bucket)</span>
                            <span class="bar-row__bar"
                                  style="--w: @((int)(100.0 * (r.AvgSymptomBurden ?? 0) / 10))%">
                            </span>
                            <span class="bar-row__count tabular">@FmtAvg(r.AvgSymptomBurden) (@r.DayCount d)</span>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (trends.CompressionVsSymptoms is not null || trends.NoCompressionVsSymptoms is not null)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.compression.label")</p>
                <ul class="bar-list">
                    @if (trends.CompressionVsSymptoms is { } cv)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@cv.Bucket</span>
                            <span class="bar-row__bar" style="--w: @((int)(100.0 * (cv.AvgSymptomBurden ?? 0) / 10))%"></span>
                            <span class="bar-row__count tabular">@FmtAvg(cv.AvgSymptomBurden) (@cv.DayCount d)</span>
                        </li>
                    }
                    @if (trends.NoCompressionVsSymptoms is { } nv)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@nv.Bucket</span>
                            <span class="bar-row__bar" style="--w: @((int)(100.0 * (nv.AvgSymptomBurden ?? 0) / 10))%"></span>
                            <span class="bar-row__count tabular">@FmtAvg(nv.AvgSymptomBurden) (@nv.DayCount d)</span>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (trends.SkipBreakfastVsSymptoms is not null || trends.RegularBreakfastVsSymptoms is not null)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.skipBreakfast.label")</p>
                <ul class="bar-list">
                    @if (trends.SkipBreakfastVsSymptoms is { } sk)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@sk.Bucket</span>
                            <span class="bar-row__bar" style="--w: @((int)(100.0 * (sk.AvgSymptomBurden ?? 0) / 10))%"></span>
                            <span class="bar-row__count tabular">@FmtAvg(sk.AvgSymptomBurden) (@sk.DayCount d)</span>
                        </li>
                    }
                    @if (trends.RegularBreakfastVsSymptoms is { } reg)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@reg.Bucket</span>
                            <span class="bar-row__bar" style="--w: @((int)(100.0 * (reg.AvgSymptomBurden ?? 0) / 10))%"></span>
                            <span class="bar-row__count tabular">@FmtAvg(reg.AvgSymptomBurden) (@reg.DayCount d)</span>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (trends.AmbientTempVsSymptoms.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.temp.label")</p>
                <ul class="bar-list">
                    @foreach (var r in trends.AmbientTempVsSymptoms)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@PrettyBucket(r.Bucket)</span>
                            <span class="bar-row__bar" style="--w: @((int)(100.0 * (r.AvgSymptomBurden ?? 0) / 10))%"></span>
                            <span class="bar-row__count tabular">@FmtAvg(r.AvgSymptomBurden) (@r.DayCount d)</span>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (trends.MenstrualPhaseVsSymptoms.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.cycle.label")</p>
                <ul class="bar-list">
                    @foreach (var r in trends.MenstrualPhaseVsSymptoms)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@PrettyBucket(r.Bucket)</span>
                            <span class="bar-row__bar" style="--w: @((int)(100.0 * (r.AvgSymptomBurden ?? 0) / 10))%"></span>
                            <span class="bar-row__count tabular">@FmtAvg(r.AvgSymptomBurden) (@r.DayCount d)</span>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (trends.ExerciseTolerance is { } ext)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.exTolerance.label")</p>
                <ul class="avg-list">
                    <li>@Lang.T("trends.exTolerance.sessions") · <strong class="tabular">@ext.TotalSessions</strong></li>
                    <li>@Lang.T("trends.exTolerance.withPost") · <strong class="tabular">@ext.SessionsWithPostSymptoms</strong></li>
                    @if (ext.SymptomBurdenWhenExercised.HasValue)
                    {
                        <li>@Lang.T("trends.exTolerance.burdenEx") · <strong class="tabular">@FmtAvg(ext.SymptomBurdenWhenExercised)</strong></li>
                    }
                    @if (ext.SymptomBurdenWhenNotExercised.HasValue)
                    {
                        <li>@Lang.T("trends.exTolerance.burdenNoEx") · <strong class="tabular">@FmtAvg(ext.SymptomBurdenWhenNotExercised)</strong></li>
                    }
                </ul>
            </section>
        }

        @if (trends.ActionsAssociatedWithFewerReds.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("trends.actionsRed.label")</p>
                <ul class="bar-list">
                    @foreach (var a in trends.ActionsAssociatedWithFewerReds)
                    {
                        <li class="bar-row">
                            <span class="bar-row__label">@a.Action</span>
                            <span class="bar-row__bar" style="--w: @((int)Math.Min(100, (a.DeltaPct ?? 0) * 5))%"></span>
                            <span class="bar-row__count tabular">−@FmtAvg(a.DeltaPct)pp</span>
                        </li>
                    }
                </ul>
                <p class="muted">
                    @Lang.T("trends.actionsRed.disclaimer.before")<em>@Lang.T("trends.actionsRed.disclaimer.em")</em>
                </p>
            </section>
        }
    }

    <hr class="divider divider--ornament" aria-hidden="true" />

    <p class="muted" style="text-align:center;">
        <a href="/today" class="btn--link">@Lang.T("trends.linkToday")</a>
        &nbsp;·&nbsp;
        <a href="/report" class="btn--link">@Lang.T("trends.linkReport")</a>
    </p>
</div>

@code {
    private TrendsDto? trends;
    private int days = 30;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await Reload(30);
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task Reload(int newDays)
    {
        days = newDays;
        loading = true;
        try { trends = await TrendsClient.GetAsync(newDays); }
        catch (HttpRequestException) { trends = null; }
        finally { loading = false; }
    }

    private static int MaxWeek(TrendsDto t) =>
        t.EpisodesPerWeek.Count == 0 ? 0 : t.EpisodesPerWeek.Max(w => w.Count);
    private static int MaxTrigger(TrendsDto t) =>
        t.TopTriggers.Count == 0 ? 0 : t.TopTriggers.Max(x => x.Count);
    private static double MaxAssoc(List<AssociationRow> rows) =>
        rows.Count == 0 ? 0 : rows.Max(r => r.AvgSymptomBurden ?? 0);
    private static string FmtAvg(double? v) => v.HasValue ? v.Value.ToString("0.0") : "—";

    // Localized short label for a backend trigger enum. Falls back to the raw
    // enum name if no translation key matches.
    private string TriggerLabel(string trigger) => trigger switch
    {
        "Unknown" => Lang.T("trigger.short.unknown"),
        "Heat" => Lang.T("trigger.heat"),
        "Dehydration" => Lang.T("trigger.dehydration"),
        "MissedMeal" => Lang.T("trigger.short.missedMeal"),
        "Menstrual" => Lang.T("trigger.menstrual"),
        "Stress" => Lang.T("trigger.stress"),
        "PoorSleep" => Lang.T("trigger.poorSleep"),
        "Exercise" => Lang.T("trigger.exercise"),
        "Infection" => Lang.T("trigger.infection"),
        "LongStanding" => Lang.T("trigger.short.longStanding"),
        "Alcohol" => Lang.T("trigger.alcohol"),
        "LargeMeal" => Lang.T("trigger.short.largeMeal"),
        _ => trigger,
    };

    // Buckets are pre-fixed with "1-", "2-" etc to preserve sort order; strip
    // the prefix before display.
    private static string PrettyBucket(string bucket)
    {
        var dash = bucket.IndexOf('-');
        return dash > 0 && dash < 3 ? bucket[(dash + 1)..] : bucket;
    }
}
