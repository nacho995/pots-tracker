@page "/log/symptoms"
@inject AuthClient Auth
@inject SymptomClient SymptomClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("symptoms.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("symptoms.eyebrow")</p>

    @if (saved)
    {
        <h1><span class="accent-rule"></span>@Lang.T("symptoms.saved.title")</h1>
        <p class="lead">@Lang.T("symptoms.saved.lead")</p>
        <div class="action-row">
            <a href="/today" class="btn--primary" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5em;text-decoration:none;">
                <span>@Lang.T("common.backToToday")</span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>
            <button class="btn--ghost" @onclick="Reset">@Lang.T("symptoms.saved.again")</button>
        </div>
    }
    else
    {
        <h1><span class="accent-rule"></span>@Lang.T("symptoms.title")</h1>
        <p class="lead">@Lang.T("symptoms.lead")</p>

        <EditForm Model="this" OnValidSubmit="SaveAsync" class="flow">

            <section class="card flow">
                <p class="card__label">@Lang.T("symptoms.cardio.label")</p>
                <SymptomScale Label="@Lang.T("symptoms.cardio.dizziness")" @bind-Value="data.Dizziness" />
                <SymptomScale Label="@Lang.T("symptoms.cardio.palpitations")" @bind-Value="data.Palpitations" />
                <SymptomScale Label="@Lang.T("symptoms.cardio.tachy")" @bind-Value="data.TachycardiaSensation" />
                <SymptomScale Label="@Lang.T("symptoms.cardio.chest")" @bind-Value="data.ChestDiscomfort" />
                <SymptomScale Label="@Lang.T("symptoms.cardio.breath")" @bind-Value="data.ShortnessOfBreath" />
                <SymptomScale Label="@Lang.T("symptoms.cardio.nearFainting")" @bind-Value="data.NearFainting" />
                <SymptomScale Label="@Lang.T("symptoms.cardio.pooling")" @bind-Value="data.BloodPooling" />
                <label class="checkbox-row">
                    <input type="checkbox" @bind="data.FaintingEpisode" />
                    <span>@Lang.T("symptoms.cardio.fainted")</span>
                </label>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("symptoms.neuro.label")</p>
                <SymptomScale Label="@Lang.T("symptoms.neuro.brainFog")" @bind-Value="data.BrainFog" />
                <SymptomScale Label="@Lang.T("symptoms.neuro.headache")" @bind-Value="data.Headache" />
                <SymptomScale Label="@Lang.T("symptoms.neuro.visual")" @bind-Value="data.VisualDisturbance" />
                <SymptomScale Label="@Lang.T("symptoms.neuro.tremor")" @bind-Value="data.Tremor" />
                <SymptomScale Label="@Lang.T("symptoms.neuro.weakness")" @bind-Value="data.Weakness" />
                <SymptomScale Label="@Lang.T("symptoms.neuro.fatigue")" @bind-Value="data.Fatigue" />
                <SymptomScale Label="@Lang.T("symptoms.neuro.sleepiness")" @bind-Value="data.Sleepiness" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("symptoms.gi.label")</p>
                <SymptomScale Label="@Lang.T("symptoms.gi.nausea")" @bind-Value="data.Nausea" />
                <SymptomScale Label="@Lang.T("symptoms.gi.abdominal")" @bind-Value="data.AbdominalPain" />
                <SymptomScale Label="@Lang.T("symptoms.gi.bloating")" @bind-Value="data.Bloating" />
                <SymptomScale Label="@Lang.T("symptoms.gi.appetite")" @bind-Value="data.AppetiteLevel" />

                <label for="bowel">@Lang.T("symptoms.gi.bowel")</label>
                <select id="bowel" class="text-input" @bind="data.Bowel">
                    <option value="">@Lang.T("common.unspecified")</option>
                    <option value="Normal">@Lang.T("symptoms.gi.bowel.normal")</option>
                    <option value="Diarrhea">@Lang.T("symptoms.gi.bowel.diarrhea")</option>
                    <option value="Constipation">@Lang.T("symptoms.gi.bowel.constipation")</option>
                    <option value="Both">@Lang.T("symptoms.gi.bowel.both")</option>
                </select>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("symptoms.auto.label")</p>
                <SymptomScale Label="@Lang.T("symptoms.auto.heat")" @bind-Value="data.HeatIntolerance" />
                <SymptomScale Label="@Lang.T("symptoms.auto.sweating")" @bind-Value="data.Sweating" />
                <SymptomScale Label="@Lang.T("symptoms.auto.chills")" @bind-Value="data.Chills" />
                <SymptomScale Label="@Lang.T("symptoms.auto.flushing")" @bind-Value="data.Flushing" />
                <SymptomScale Label="@Lang.T("symptoms.auto.cold")" @bind-Value="data.ColdExtremities" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("symptoms.func.label")</p>
                <SymptomScale Label="@Lang.T("symptoms.func.anxiety")" @bind-Value="data.Anxiety" />
                <SymptomScale Label="@Lang.T("symptoms.func.mood")" @bind-Value="data.Mood" />
                <SymptomScale Label="@Lang.T("symptoms.func.work")" @bind-Value="data.AbilityToWork" />
                <SymptomScale Label="@Lang.T("symptoms.func.walk")" @bind-Value="data.AbilityToWalk" />
                <SymptomScale Label="@Lang.T("symptoms.func.social")" @bind-Value="data.SocialTolerance" />
            </section>

            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }

            <div class="action-row">
                <button type="submit" class="btn--primary" disabled="@busy">
                    <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                    <span class="arrow" aria-hidden="true">→</span>
                </button>
                <a href="/today" class="btn--ghost" style="text-decoration:none;text-align:center;display:inline-flex;align-items:center;justify-content:center;">
                    @Lang.T("cancel")
                </a>
            </div>
        </EditForm>
    }
</div>

@code {
    private SymptomsForm data = new();
    private bool busy;
    private bool saved;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task SaveAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            await SymptomClient.RecordAsync(new RecordSymptomsDto
            {
                Dizziness = data.Dizziness,
                Palpitations = data.Palpitations,
                TachycardiaSensation = data.TachycardiaSensation,
                ChestDiscomfort = data.ChestDiscomfort,
                ShortnessOfBreath = data.ShortnessOfBreath,
                NearFainting = data.NearFainting,
                FaintingEpisode = data.FaintingEpisode,
                BloodPooling = data.BloodPooling,
                BrainFog = data.BrainFog,
                Headache = data.Headache,
                VisualDisturbance = data.VisualDisturbance,
                Tremor = data.Tremor,
                Weakness = data.Weakness,
                Fatigue = data.Fatigue,
                Sleepiness = data.Sleepiness,
                Nausea = data.Nausea,
                AbdominalPain = data.AbdominalPain,
                Bloating = data.Bloating,
                Bowel = string.IsNullOrEmpty(data.Bowel) ? null : data.Bowel,
                AppetiteLevel = data.AppetiteLevel,
                HeatIntolerance = data.HeatIntolerance,
                Sweating = data.Sweating,
                Chills = data.Chills,
                Flushing = data.Flushing,
                ColdExtremities = data.ColdExtremities,
                Anxiety = data.Anxiety,
                Mood = data.Mood,
                AbilityToWork = data.AbilityToWork,
                AbilityToWalk = data.AbilityToWalk,
                SocialTolerance = data.SocialTolerance,
            });
            saved = true;
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("common.saveError");
        }
        finally { busy = false; }
    }

    private void Reset()
    {
        data = new SymptomsForm();
        saved = false;
        errorMessage = null;
    }

    private sealed class SymptomsForm
    {
        public int? Dizziness { get; set; }
        public int? Palpitations { get; set; }
        public int? TachycardiaSensation { get; set; }
        public int? ChestDiscomfort { get; set; }
        public int? ShortnessOfBreath { get; set; }
        public int? NearFainting { get; set; }
        public bool FaintingEpisode { get; set; }
        public int? BloodPooling { get; set; }
        public int? BrainFog { get; set; }
        public int? Headache { get; set; }
        public int? VisualDisturbance { get; set; }
        public int? Tremor { get; set; }
        public int? Weakness { get; set; }
        public int? Fatigue { get; set; }
        public int? Sleepiness { get; set; }
        public int? Nausea { get; set; }
        public int? AbdominalPain { get; set; }
        public int? Bloating { get; set; }
        public string Bowel { get; set; } = "";
        public int? AppetiteLevel { get; set; }
        public int? HeatIntolerance { get; set; }
        public int? Sweating { get; set; }
        public int? Chills { get; set; }
        public int? Flushing { get; set; }
        public int? ColdExtremities { get; set; }
        public int? Anxiety { get; set; }
        public int? Mood { get; set; }
        public int? AbilityToWork { get; set; }
        public int? AbilityToWalk { get; set; }
        public int? SocialTolerance { get; set; }
    }
}
