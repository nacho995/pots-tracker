@page "/settings"
@inject AuthClient Auth
@inject TargetsClient TargetsClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("settings.pageTitle")</PageTitle>

<div class="shell flow stagger">
    <p class="eyebrow">@Lang.T("settings.eyebrow")</p>
    <h1><span class="accent-rule"></span>@Lang.T("settings.title")</h1>
    <p class="lead">@Lang.T("settings.lead")</p>

    @if (loading)
    {
        <p>@Lang.T("loading")...</p>
    }
    else
    {
        <EditForm Model="this" OnValidSubmit="SaveAsync" class="flow">
            <section class="card flow">
                <p class="card__label">@Lang.T("settings.hydration.label")</p>
                <label for="hydration">@Lang.T("settings.hydration.target")</label>
                <input id="hydration" type="number" min="0" max="20000" @bind="form.HydrationTargetMl" />
                <p class="muted">@Lang.T("settings.hydration.hint")</p>
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("settings.compression.label")</p>
                <label for="compression">@Lang.T("settings.compression.target")</label>
                <input id="compression" type="number" min="0" max="24" @bind="form.CompressionGoalHoursPerDay" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("settings.sleep.label")</p>
                <label for="sleep">@Lang.T("settings.sleep.target")</label>
                <input id="sleep" type="number" step="0.5" min="0" max="24" @bind="form.SleepTargetHours" />
            </section>

            <section class="card flow">
                <p class="card__label">@Lang.T("settings.exercise.label")</p>
                <label for="ex-plan" class="visually-hidden">@Lang.T("settings.exercise.label")</label>
                <textarea id="ex-plan" class="text-input" rows="4" maxlength="2000"
                          @bind="form.ExercisePlanNote"
                          placeholder="@Lang.T("settings.exercise.placeholder")"></textarea>
            </section>

            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>@(busy ? Lang.T("saving") : Lang.T("settings.saveBtn"))</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        <hr class="divider" aria-hidden="true" />

        @* Salt feature is clinician-gated per CLAUDE.md §2: never default on,
           require explicit clinician attestation, allow easy disable. *@
        <section class="card flow @(saltEnabled ? "card--accent" : "")">
            <p class="card__label">@Lang.T("settings.salt.label")</p>

            @if (!saltEnabled)
            {
                <h2>@Lang.T("settings.salt.offTitle")</h2>
                <p>
                    @Lang.T("settings.salt.warning.before")<strong>@Lang.T("settings.salt.warning.strong")</strong>@Lang.T("settings.salt.warning.after")
                </p>

                @if (!showSaltModal)
                {
                    <button type="button" class="btn--ghost" @onclick="ShowSaltModal" disabled="@busy">
                        @Lang.T("settings.salt.activate")
                    </button>
                }
                else
                {
                    <div class="salt-form">
                        <label for="salt-mg">@Lang.T("settings.salt.targetMg")</label>
                        <input id="salt-mg" type="number" min="0" max="50000" @bind="saltMg" placeholder="@Lang.T("settings.salt.targetMgPlaceholder")" />

                        <label for="attestation">@Lang.T("settings.salt.attestation")</label>
                        <textarea id="attestation" class="text-input" rows="3" maxlength="2000"
                                  @bind="attestation"
                                  placeholder="@Lang.T("settings.salt.attestationPlaceholder")"></textarea>

                        <p class="muted">@Lang.T("settings.salt.attestationHint")</p>

                        @if (saltError is not null)
                        {
                            <p class="error-text" role="alert">@saltError</p>
                        }

                        <div class="action-row">
                            <button type="button" class="btn--primary" @onclick="EnableSaltAsync" disabled="@busy">
                                @Lang.T("settings.salt.confirm")
                            </button>
                            <button type="button" class="btn--ghost" @onclick="HideSaltModal" disabled="@busy">
                                @Lang.T("cancel")
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <h2>@Lang.T("settings.salt.activeTitle")</h2>
                <p class="card__value">@(targets?.SaltTargetMg) @Lang.T("settings.salt.unit")</p>
                @if (!string.IsNullOrEmpty(targets?.SaltClinicianAttestation))
                {
                    <p class="muted">@targets.SaltClinicianAttestation</p>
                }
                <button type="button" class="btn--ghost" @onclick="DisableSaltAsync" disabled="@busy">
                    @Lang.T("settings.salt.disable")
                </button>
            }
        </section>
    }

    <hr class="divider divider--ornament" aria-hidden="true" />

    <p class="muted" style="text-align:center;">
        <a href="/profile" class="btn--link">@Lang.T("settings.linkProfile")</a>
        &nbsp;·&nbsp;
        <a href="/today" class="btn--link">@Lang.T("settings.linkToday")</a>
    </p>
</div>

@code {
    private PatientTargetsDto? targets;
    private SettingsForm form = new();
    private bool loading = true;
    private bool busy = false;
    private string? errorMessage;
    private bool saltEnabled = false;

    private bool showSaltModal = false;
    private int saltMg = 6000;
    private string attestation = "";
    private string? saltError;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await LoadAsync();
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private async Task LoadAsync()
    {
        loading = true;
        try
        {
            targets = await TargetsClient.GetAsync();
            form.HydrationTargetMl = targets.HydrationTargetMl;
            form.CompressionGoalHoursPerDay = targets.CompressionGoalHoursPerDay;
            form.SleepTargetHours = targets.SleepTargetHours;
            form.ExercisePlanNote = targets.ExercisePlanNote ?? "";
            form.Language = string.IsNullOrEmpty(targets.Language) ? "es" : targets.Language;
            saltEnabled = targets.SaltTargetEnabled;
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("settings.loadError");
        }
        finally { loading = false; }
    }

    private async Task SaveAsync()
    {
        errorMessage = null;
        busy = true;
        try
        {
            targets = await TargetsClient.UpdateAsync(new UpdateTargetsDto(
                HydrationTargetMl: form.HydrationTargetMl,
                CompressionGoalHoursPerDay: form.CompressionGoalHoursPerDay,
                ExercisePlanNote: string.IsNullOrWhiteSpace(form.ExercisePlanNote) ? null : form.ExercisePlanNote,
                SleepTargetHours: form.SleepTargetHours,
                Language: form.Language));
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("common.saveError");
        }
        finally { busy = false; }
    }

    private void ShowSaltModal()
    {
        showSaltModal = true;
        saltError = null;
    }

    private void HideSaltModal()
    {
        showSaltModal = false;
        attestation = "";
        saltError = null;
    }

    private async Task EnableSaltAsync()
    {
        saltError = null;
        if (string.IsNullOrWhiteSpace(attestation))
        {
            saltError = Lang.T("settings.salt.attestationRequired");
            return;
        }
        busy = true;
        try
        {
            targets = await TargetsClient.EnableSaltAsync(new EnableSaltTargetDto(saltMg, attestation));
            saltEnabled = true;
            showSaltModal = false;
            attestation = "";
        }
        catch (HttpRequestException)
        {
            saltError = Lang.T("settings.salt.activateError");
        }
        finally { busy = false; }
    }

    private async Task DisableSaltAsync()
    {
        busy = true;
        try
        {
            await TargetsClient.DisableSaltAsync();
            await LoadAsync();
        }
        finally { busy = false; }
    }

    private sealed class SettingsForm
    {
        public int HydrationTargetMl { get; set; } = 2500;
        public int? CompressionGoalHoursPerDay { get; set; }
        public decimal? SleepTargetHours { get; set; }
        public string ExercisePlanNote { get; set; } = "";
        public string Language { get; set; } = "es";
    }
}
