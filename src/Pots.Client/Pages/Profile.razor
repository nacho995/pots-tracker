@page "/profile"
@inject AuthClient Auth
@inject AccountClient AccountClient
@inject PatientClient PatientClient
@inject RoleContextService Roles
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

@* Phase 6 — /profile is now USER-ACCOUNT first.
   Every user has a name+email (Tu cuenta section).
   Patients additionally get a "Tu perfil POTS" section with permissions+notes.
   Caregivers see their account + a link to shared dashboards, NOT a CTA to
   create a Patient (the pre-Phase-6 trap that turned caregivers into
   accidental patients). The "I also have POTS" path still exists but is
   gated by an explicit confirmation. *@

<PageTitle>POTS</PageTitle>

<div class="shell flow stagger">
    @if (loading)
    {
        <p class="eyebrow">@Lang.T("loading")</p>
        <h1><span class="accent-rule"></span>@Lang.T("moment")</h1>
    }
    else if (account is null)
    {
        <p class="eyebrow">@Lang.T("loading")</p>
        <h1><span class="accent-rule"></span>@Lang.T("profile.error.load")</h1>
    }
    else
    {
        <p class="eyebrow">@Lang.T("profile.eyebrow") · @FormatToday()</p>
        <h1>
            <span class="accent-rule"></span>
            @GreetingFor()@(string.IsNullOrEmpty(account.DisplayName) ? "." : ", " + account.DisplayName + ".")
        </h1>
        <p class="muted">@account.Email</p>

        <hr class="divider" aria-hidden="true" />

        @* === Tu cuenta (always visible) === *@
        <section class="card">
            @if (!editingAccount)
            {
                <p class="card__label">@Lang.T("profile.account.label")</p>
                <div class="card__row">
                    <p class="card__value">
                        @(string.IsNullOrEmpty(account.DisplayName)
                            ? Lang.T("profile.account.namePrompt")
                            : account.DisplayName)
                    </p>
                    <button class="btn--link" @onclick="StartEditAccount">
                        @(string.IsNullOrEmpty(account.DisplayName)
                            ? Lang.T("profile.account.setName")
                            : Lang.T("profile.edit")) →
                    </button>
                </div>
                <p class="muted">@Lang.T("profile.account.help")</p>
            }
            else
            {
                <p class="card__label">@Lang.T("profile.account.label")</p>
                <EditForm Model="this" OnValidSubmit="SaveAccountAsync">
                    <div>
                        <label for="display-name-edit" class="visually-hidden">@Lang.T("profile.yourName")</label>
                        <input id="display-name-edit" type="text" @bind="displayNameInput"
                               required maxlength="100" disabled="@busy" autofocus
                               placeholder="@Lang.T("profile.yourName")" />
                    </div>
                    <div class="action-row">
                        <button type="submit" class="btn--primary" disabled="@busy">
                            <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </button>
                        <button type="button" class="btn--ghost" @onclick="CancelEditAccount" disabled="@busy">
                            @Lang.T("cancel")
                        </button>
                    </div>
                </EditForm>
            }
            @if (accountError is not null)
            {
                <p class="error-text" role="alert">@accountError</p>
            }
        </section>

        @* === Tu perfil POTS (only if user is a patient) === *@
        @if (patient is not null)
        {
            <section class="card card--sunk">
                @if (!editingPatient)
                {
                    <p class="card__label">@Lang.T("profile.patient.label")</p>
                    <div class="card__row">
                        <p class="card__value">@patient.Name</p>
                        <button class="btn--link" @onclick="StartEditPatient">@Lang.T("profile.edit") →</button>
                    </div>
                }
                else
                {
                    <p class="card__label">@Lang.T("profile.patient.label")</p>
                    <EditForm Model="this" OnValidSubmit="SavePatientAsync">
                        <div>
                            <label for="patient-name-edit" class="visually-hidden">@Lang.T("profile.patient.label")</label>
                            <input id="patient-name-edit" type="text" @bind="patientNameInput"
                                   required maxlength="100" disabled="@busy" autofocus />
                        </div>
                        <div class="action-row">
                            <button type="submit" class="btn--primary" disabled="@busy">
                                <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                            </button>
                            <button type="button" class="btn--ghost" @onclick="CancelEditPatient" disabled="@busy">
                                @Lang.T("cancel")
                            </button>
                        </div>
                    </EditForm>
                }
                @if (patientError is not null)
                {
                    <p class="error-text" role="alert">@patientError</p>
                }
            </section>

            <section class="card card--sunk">
                <p class="card__label">@Lang.T("profile.permissions")</p>
                <h2>@Lang.T("profile.permissions.title")</h2>
                <p>@Lang.T("profile.permissions.lead")</p>
                <a href="/grants" class="btn--link">@Lang.T("profile.permissions.manage")</a>
            </section>

            <section class="card card--sunk">
                <p class="card__label">@Lang.T("profile.notes")</p>
                <h2>@Lang.T("profile.notes.title")</h2>
                <p>@Lang.T("profile.notes.lead")</p>
                <a href="@($"/shared/{patient.Id}/notes")" class="btn--link">@Lang.T("profile.notes.open")</a>
            </section>
        }
        else if (account.HasSharedAccess)
        {
            @* Caregiver-only: no patient, but has grants. Direct them to /shared. *@
            <section class="card card--sunk">
                <p class="card__label">@Lang.T("profile.caregiver.label")</p>
                <h2>@Lang.T("profile.caregiver.title")</h2>
                <p>@Lang.T("profile.caregiver.lead")</p>
                <a href="/shared" class="btn--link">@Lang.T("profile.caregiver.open") →</a>
            </section>

            @* "I ALSO have POTS" — escondido detrás de un detalle desplegable
               para evitar clicks accidentales. *@
            <details class="card card--sunk">
                <summary class="card__label">@Lang.T("profile.alsoPatient.summary")</summary>
                <p>@Lang.T("profile.alsoPatient.help")</p>
                @if (!alsoPatientFormOpen)
                {
                    <button class="btn--ghost" @onclick="@(() => alsoPatientFormOpen = true)">
                        @Lang.T("profile.alsoPatient.openForm")
                    </button>
                }
                else
                {
                    <EditForm Model="this" OnValidSubmit="CreatePatientWithConfirmAsync">
                        <div>
                            <label for="also-patient-name">@Lang.T("profile.alsoPatient.patientName")</label>
                            <input id="also-patient-name" type="text" @bind="patientNameInput"
                                   required maxlength="100" disabled="@busy"
                                   placeholder="@Lang.T("profile.alsoPatient.patientNamePlaceholder")" />
                        </div>
                        <p class="muted">@Lang.T("profile.alsoPatient.warning")</p>
                        <div class="action-row">
                            <button type="submit" class="btn--primary" disabled="@busy">
                                <span>@(busy ? Lang.T("saving") : Lang.T("profile.alsoPatient.confirm"))</span>
                            </button>
                            <button type="button" class="btn--ghost" @onclick="@(() => alsoPatientFormOpen = false)" disabled="@busy">
                                @Lang.T("cancel")
                            </button>
                        </div>
                    </EditForm>
                    @if (patientError is not null)
                    {
                        <p class="error-text" role="alert">@patientError</p>
                    }
                }
            </details>
        }
        else
        {
            @* No patient, no grants — true onboarding. Offer the patient
               creation but with a clear "are you the POTS patient?" framing. *@
            <section class="card card--sunk">
                <p class="card__label">@Lang.T("profile.firstTime.label")</p>
                <h2>@Lang.T("profile.firstTime.title")</h2>
                <p>@Lang.T("profile.firstTime.lead")</p>
                @if (!alsoPatientFormOpen)
                {
                    <button class="btn--primary" style="display:inline-flex;width:auto;"
                            @onclick="@(() => alsoPatientFormOpen = true)">
                        <span>@Lang.T("profile.firstTime.iAmPatient")</span>
                        <span class="arrow" aria-hidden="true">→</span>
                    </button>
                    <p class="muted" style="margin-top:1rem;">@Lang.T("profile.firstTime.iAmCaregiver")</p>
                }
                else
                {
                    <EditForm Model="this" OnValidSubmit="CreatePatientFreshAsync">
                        <div>
                            <label for="fresh-patient-name">@Lang.T("profile.firstTime.patientName")</label>
                            <input id="fresh-patient-name" type="text" @bind="patientNameInput"
                                   required maxlength="100" disabled="@busy" autofocus />
                        </div>
                        <div class="action-row">
                            <button type="submit" class="btn--primary" disabled="@busy">
                                <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                            </button>
                            <button type="button" class="btn--ghost" @onclick="@(() => alsoPatientFormOpen = false)" disabled="@busy">
                                @Lang.T("cancel")
                            </button>
                        </div>
                    </EditForm>
                    @if (patientError is not null)
                    {
                        <p class="error-text" role="alert">@patientError</p>
                    }
                }
            </section>
        }

        <hr class="divider divider--ornament" aria-hidden="true" />

        <button class="btn--quiet" @onclick="SignOutAsync">@Lang.T("profile.signout")</button>
    }
</div>

@code {
    private AccountDto? account;
    private PatientDto? patient;
    private bool loading = true;
    private bool busy = false;

    private bool editingAccount = false;
    private string displayNameInput = "";
    private string? accountError;

    private bool editingPatient = false;
    private string patientNameInput = "";
    private string? patientError;
    private bool alsoPatientFormOpen = false;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            account = await AccountClient.GetAsync();
            displayNameInput = account?.DisplayName ?? "";
            if (account?.IsPatient == true)
            {
                patient = await PatientClient.GetMyPatientAsync();
                patientNameInput = patient?.Name ?? "";
            }
        }
        catch (HttpRequestException)
        {
            accountError = Lang.T("profile.error.load");
        }
        finally
        {
            loading = false;
        }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private void StartEditAccount() { editingAccount = true; displayNameInput = account!.DisplayName ?? ""; accountError = null; }
    private void CancelEditAccount() { editingAccount = false; displayNameInput = account!.DisplayName ?? ""; }

    private async Task SaveAccountAsync()
    {
        accountError = null; busy = true;
        try
        {
            account = await AccountClient.UpdateDisplayNameAsync(displayNameInput);
            editingAccount = false;
        }
        catch (HttpRequestException) { accountError = Lang.T("profile.error.save"); }
        finally { busy = false; }
    }

    private void StartEditPatient() { editingPatient = true; patientNameInput = patient!.Name; patientError = null; }
    private void CancelEditPatient() { editingPatient = false; patientNameInput = patient!.Name; }

    private async Task SavePatientAsync()
    {
        patientError = null; busy = true;
        try { patient = await PatientClient.RenameMyPatientAsync(patientNameInput); editingPatient = false; }
        catch (HttpRequestException) { patientError = Lang.T("profile.error.save"); }
        finally { busy = false; }
    }

    private async Task CreatePatientFreshAsync()
    {
        patientError = null; busy = true;
        try
        {
            patient = await PatientClient.CreateMyPatientAsync(patientNameInput);
            account = await AccountClient.GetAsync(); // refresh isPatient flag
            Roles.Invalidate();
            alsoPatientFormOpen = false;
        }
        catch (HttpRequestException) { patientError = Lang.T("profile.error.save"); }
        finally { busy = false; }
    }

    private async Task CreatePatientWithConfirmAsync()
    {
        patientError = null; busy = true;
        try
        {
            patient = await PatientClient.CreateMyPatientAsync(patientNameInput, confirmAlsoPatient: true);
            account = await AccountClient.GetAsync();
            Roles.Invalidate();
            alsoPatientFormOpen = false;
        }
        catch (HttpRequestException) { patientError = Lang.T("profile.error.save"); }
        finally { busy = false; }
    }

    private async Task SignOutAsync()
    {
        await Auth.SignOutAsync();
        Nav.NavigateTo("/login", replace: true);
    }

    private string FormatToday()
    {
        var d = DateTime.Now;
        var months = Lang.Current switch
        {
            "fr" => new[] { "janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre" },
            "en" => new[] { "January","February","March","April","May","June","July","August","September","October","November","December" },
            _    => new[] { "enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre" },
        };
        var sep = Lang.Current == "en" ? " " : " de ";
        return Lang.Current == "en" ? $"{months[d.Month - 1]} {d.Day}" : $"{d.Day}{sep}{months[d.Month - 1]}";
    }

    private string GreetingFor()
    {
        var h = DateTime.Now.Hour;
        var slot = h < 6 ? "evening" : h < 13 ? "morning" : h < 21 ? "afternoon" : "evening";
        return Lang.T($"greet.{slot}");
    }
}
