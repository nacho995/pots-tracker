@page "/profile"
@inject AuthClient Auth
@inject PatientClient PatientClient
@inject NavigationManager Nav

<PageTitle>Tu perfil — POTS</PageTitle>

<div class="shell flow stagger">
    @if (loading)
    {
        <p class="eyebrow">Cargando</p>
        <h1><span class="accent-rule"></span>Un momento.</h1>
    }
    else if (patient is null)
    {
        <p class="eyebrow">Empezamos</p>
        <h1><span class="accent-rule"></span>Bienvenida.</h1>
        <p class="lead">
            Dinos cómo te llamas. Solo tú podrás editarlo, salvo que des
            permiso a otra persona.
        </p>

        <EditForm Model="this" OnValidSubmit="CreateAsync">
            <div>
                <label for="name-input">Tu nombre</label>
                <input id="name-input" type="text" @bind="nameInput" required maxlength="100"
                       placeholder="Tu nombre" disabled="@busy" autofocus />
            </div>

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>@(busy ? "Guardando..." : "Guardar")</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        @if (errorMessage is not null)
        {
            <p class="error-text" role="alert">@errorMessage</p>
        }
    }
    else
    {
        <p class="eyebrow">Tu perfil · @FormatToday()</p>

        <h1><span class="accent-rule"></span>@GreetingFor() <em>@patient.Name</em>.</h1>

        <p class="muted">Sesión iniciada como @(Auth.GetEmailFromJwt() ?? "")</p>

        <hr class="divider" aria-hidden="true" />

        <section class="card">
            @if (!editing)
            {
                <p class="card__label">Tu nombre</p>
                <div class="card__row">
                    <p class="card__value">@patient.Name</p>
                    <button class="btn--link" @onclick="StartEdit">Editar →</button>
                </div>
            }
            else
            {
                <p class="card__label">Editar nombre</p>
                <EditForm Model="this" OnValidSubmit="SaveAsync">
                    <div>
                        <label for="name-edit" class="visually-hidden">Nombre</label>
                        <input id="name-edit" type="text" @bind="nameInput" required maxlength="100"
                               disabled="@busy" autofocus />
                    </div>
                    <div class="action-row">
                        <button type="submit" class="btn--primary" disabled="@busy">
                            <span>@(busy ? "Guardando..." : "Guardar")</span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </button>
                        <button type="button" class="btn--ghost" @onclick="CancelEdit" disabled="@busy">
                            Cancelar
                        </button>
                    </div>
                </EditForm>
            }
            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }
        </section>

        <section class="card card--sunk">
            <p class="card__label">Permisos</p>
            <h2>Quién puede ver o editar tus datos</h2>
            <p>Por defecto, solo tú. Aquí puedes dar acceso a otra persona y revocarlo cuando quieras.</p>
            <a href="/grants" class="btn--link">Gestionar permisos →</a>
        </section>

        <hr class="divider divider--ornament" aria-hidden="true" />

        <button class="btn--quiet" @onclick="SignOutAsync">Cerrar sesión</button>
    }
</div>

@code {
    private static readonly string[] MonthsEs =
        { "enero", "febrero", "marzo", "abril", "mayo", "junio",
          "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre" };

    private PatientDto? patient;
    private bool loading = true;
    private bool editing = false;
    private bool busy = false;
    private string nameInput = "";
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            patient = await PatientClient.GetMyPatientAsync();
            nameInput = patient?.Name ?? "";
        }
        catch (HttpRequestException)
        {
            errorMessage = "No se pudo cargar tu perfil.";
        }
        finally
        {
            loading = false;
        }
    }

    private void StartEdit() { editing = true; nameInput = patient!.Name; errorMessage = null; }
    private void CancelEdit() { editing = false; nameInput = patient!.Name; }

    private async Task CreateAsync()
    {
        errorMessage = null; busy = true;
        try { patient = await PatientClient.CreateMyPatientAsync(nameInput); }
        catch (HttpRequestException) { errorMessage = "No se pudo guardar. Inténtalo de nuevo."; }
        finally { busy = false; }
    }

    private async Task SaveAsync()
    {
        errorMessage = null; busy = true;
        try { patient = await PatientClient.RenameMyPatientAsync(nameInput); editing = false; }
        catch (HttpRequestException) { errorMessage = "No se pudo guardar. Inténtalo de nuevo."; }
        finally { busy = false; }
    }

    private async Task SignOutAsync()
    {
        await Auth.SignOutAsync();
        Nav.NavigateTo("/login", replace: true);
    }

    private static string FormatToday()
    {
        var d = DateTime.Now;
        return $"{d.Day} de {MonthsEs[d.Month - 1]}";
    }

    private static string GreetingFor()
    {
        var h = DateTime.Now.Hour;
        if (h < 6)  return "Buenas noches,";
        if (h < 13) return "Buenos días,";
        if (h < 21) return "Buenas tardes,";
        return "Buenas noches,";
    }
}
