@page "/profile"
@inject AuthClient Auth
@inject PatientClient PatientClient
@inject NavigationManager Nav
@inject LanguageService Lang
@implements IDisposable

<PageTitle>POTS</PageTitle>

<div class="shell flow stagger">
    @if (loading)
    {
        <p class="eyebrow">@Lang.T("loading")</p>
        <h1><span class="accent-rule"></span>@Lang.T("moment")</h1>
    }
    else if (patient is null)
    {
        <p class="eyebrow">@Lang.T("profile.welcome.eyebrow")</p>
        <h1><span class="accent-rule"></span>@Lang.T("profile.welcome.title")</h1>
        <p class="lead">@Lang.T("profile.welcome.lead")</p>

        <EditForm Model="this" OnValidSubmit="CreateAsync">
            <div>
                <label for="name-input">@Lang.T("profile.yourName")</label>
                <input id="name-input" type="text" @bind="nameInput" required maxlength="100"
                       placeholder="@Lang.T("profile.yourName")" disabled="@busy" autofocus />
            </div>

            <button type="submit" class="btn--primary" disabled="@busy">
                <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                <span class="arrow" aria-hidden="true">→</span>
            </button>
        </EditForm>

        @if (errorMessage is not null)
        {
            <p class="error-text" role="alert">@errorMessage</p>
        }
    }
    else
    {
        <p class="eyebrow">@Lang.T("profile.eyebrow") · @FormatToday()</p>

        <h1><span class="accent-rule"></span>@GreetingFor(), <em>@patient.Name</em>.</h1>

        <p class="muted">@Lang.T("profile.session") @(Auth.GetEmailFromJwt() ?? "")</p>

        <hr class="divider" aria-hidden="true" />

        <section class="card">
            @if (!editing)
            {
                <p class="card__label">@Lang.T("profile.yourName")</p>
                <div class="card__row">
                    <p class="card__value">@patient.Name</p>
                    <button class="btn--link" @onclick="StartEdit">@Lang.T("profile.edit") →</button>
                </div>
            }
            else
            {
                <p class="card__label">@Lang.T("profile.edit")</p>
                <EditForm Model="this" OnValidSubmit="SaveAsync">
                    <div>
                        <label for="name-edit" class="visually-hidden">@Lang.T("profile.yourName")</label>
                        <input id="name-edit" type="text" @bind="nameInput" required maxlength="100"
                               disabled="@busy" autofocus />
                    </div>
                    <div class="action-row">
                        <button type="submit" class="btn--primary" disabled="@busy">
                            <span>@(busy ? Lang.T("saving") : Lang.T("save"))</span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </button>
                        <button type="button" class="btn--ghost" @onclick="CancelEdit" disabled="@busy">
                            @Lang.T("cancel")
                        </button>
                    </div>
                </EditForm>
            }
            @if (errorMessage is not null)
            {
                <p class="error-text" role="alert">@errorMessage</p>
            }
        </section>

        <section class="card card--sunk">
            <p class="card__label">@Lang.T("profile.permissions")</p>
            <h2>@Lang.T("profile.permissions.title")</h2>
            <p>@Lang.T("profile.permissions.lead")</p>
            <a href="/grants" class="btn--link">@Lang.T("profile.permissions.manage")</a>
        </section>

        <section class="card card--sunk">
            <p class="card__label">@Lang.T("profile.notes")</p>
            <h2>@Lang.T("profile.notes.title")</h2>
            <p>@Lang.T("profile.notes.lead")</p>
            <a href="@($"/shared/{patient.Id}/notes")" class="btn--link">@Lang.T("profile.notes.open")</a>
        </section>

        <hr class="divider divider--ornament" aria-hidden="true" />

        <button class="btn--quiet" @onclick="SignOutAsync">@Lang.T("profile.signout")</button>
    }
</div>

@code {
    private PatientDto? patient;
    private bool loading = true;
    private bool editing = false;
    private bool busy = false;
    private string nameInput = "";
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            patient = await PatientClient.GetMyPatientAsync();
            nameInput = patient?.Name ?? "";
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("profile.error.load");
        }
        finally
        {
            loading = false;
        }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;

    private void StartEdit() { editing = true; nameInput = patient!.Name; errorMessage = null; }
    private void CancelEdit() { editing = false; nameInput = patient!.Name; }

    private async Task CreateAsync()
    {
        errorMessage = null; busy = true;
        try { patient = await PatientClient.CreateMyPatientAsync(nameInput); }
        catch (HttpRequestException) { errorMessage = Lang.T("profile.error.save"); }
        finally { busy = false; }
    }

    private async Task SaveAsync()
    {
        errorMessage = null; busy = true;
        try { patient = await PatientClient.RenameMyPatientAsync(nameInput); editing = false; }
        catch (HttpRequestException) { errorMessage = Lang.T("profile.error.save"); }
        finally { busy = false; }
    }

    private async Task SignOutAsync()
    {
        await Auth.SignOutAsync();
        Nav.NavigateTo("/login", replace: true);
    }

    private string FormatToday()
    {
        var d = DateTime.Now;
        var months = Lang.Current switch
        {
            "fr" => new[] { "janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre" },
            "en" => new[] { "January","February","March","April","May","June","July","August","September","October","November","December" },
            _    => new[] { "enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre" },
        };
        var sep = Lang.Current == "en" ? " " : " de ";
        return Lang.Current == "en" ? $"{months[d.Month - 1]} {d.Day}" : $"{d.Day}{sep}{months[d.Month - 1]}";
    }

    private string GreetingFor()
    {
        var h = DateTime.Now.Hour;
        var slot = h < 6 ? "evening" : h < 13 ? "morning" : h < 21 ? "afternoon" : "evening";
        return Lang.T($"greet.{slot}");
    }
}
