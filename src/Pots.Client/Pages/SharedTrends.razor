@page "/shared/{PatientId:guid}/trends"
@inject AuthClient Auth
@inject SharedPatientClient SharedPatients
@inject LanguageService Lang
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@(patient?.Name ?? Lang.T("loading")) · @Lang.T("shared.trends.title")</PageTitle>

<div class="shell flow stagger">
    @if (loading)
    {
        <p class="eyebrow">@Lang.T("loading")</p>
        <h1><span class="accent-rule"></span>@Lang.T("shared.trends.title")</h1>
    }
    else if (patient is null || trends is null)
    {
        <p class="eyebrow">@Lang.T("shared.dashboard.notFound.eyebrow")</p>
        <h1><span class="accent-rule"></span>@Lang.T("shared.dashboard.notFound.title")</h1>
        <a href="/shared" class="btn--link">@Lang.T("shared.dashboard.back")</a>
    }
    else
    {
        <p class="eyebrow">@string.Format(Lang.T("shared.trends.eyebrow"), patient.Name)</p>
        <h1><span class="accent-rule"></span>@string.Format(Lang.T("shared.trends.title.range"), trends.RangeDays)</h1>
        <p class="lead">@Lang.T("shared.trends.disclaimer")</p>

        <section class="card flow">
            <p class="card__label">@Lang.T("shared.trends.statusBreakdown")</p>
            <dl class="scale-list">
                <div class="scale-list__row"><dt>@Lang.T("today.green")</dt><dd><strong>@trends.GreenCount</strong></dd></div>
                <div class="scale-list__row"><dt>@Lang.T("today.orange")</dt><dd><strong>@trends.OrangeCount</strong></dd></div>
                <div class="scale-list__row"><dt>@Lang.T("today.red")</dt><dd><strong>@trends.RedCount</strong></dd></div>
                <div class="scale-list__row"><dt>@Lang.T("shared.trends.episodes")</dt><dd><strong>@trends.EpisodeCount</strong></dd></div>
            </dl>
        </section>

        @if (trends.AvgFatigue is double f || trends.AvgBrainFog is double b || trends.AvgDizziness is double d)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("shared.trends.avgSymptoms")</p>
                <dl class="scale-list">
                    @if (trends.AvgFatigue is double af)    { <div class="scale-list__row"><dt>@Lang.T("symptom.fatigue")</dt><dd><strong>@af</strong> / 10</dd></div> }
                    @if (trends.AvgBrainFog is double abf)  { <div class="scale-list__row"><dt>@Lang.T("symptom.brainFog")</dt><dd><strong>@abf</strong> / 10</dd></div> }
                    @if (trends.AvgDizziness is double ad)  { <div class="scale-list__row"><dt>@Lang.T("symptom.dizziness")</dt><dd><strong>@ad</strong> / 10</dd></div> }
                </dl>
            </section>
        }

        @if (trends.TopTriggers.Count > 0)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("shared.trends.topTriggers")</p>
                <ul class="check-list">
                    @foreach (var t in trends.TopTriggers)
                    {
                        <li>@t.Trigger · <strong>@t.Count</strong></li>
                    }
                </ul>
            </section>
        }

        @if (trends.BestWorst is { } bw)
        {
            <section class="card flow">
                <p class="card__label">@Lang.T("shared.trends.bestWorst")</p>
                <p>@Lang.T("shared.trends.bestDay"): <strong>@bw.BestDay</strong> (V=@bw.BestGreen / R=@bw.BestRed)</p>
                <p>@Lang.T("shared.trends.worstDay"): <strong>@bw.WorstDay</strong> (V=@bw.WorstGreen / R=@bw.WorstRed)</p>
            </section>
        }

        <hr class="divider divider--ornament" aria-hidden="true" />
        <p class="muted" style="text-align:center;">
            <a href="@($"/shared/{PatientId}")" class="btn--link">@Lang.T("shared.episodes.back")</a>
        </p>
    }
</div>

@code {
    [Parameter] public Guid PatientId { get; set; }

    private SharedPatientContextDto? patient;
    private TrendsDto? trends;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        Lang.LanguageChanged += OnLangChanged;
        if (string.IsNullOrEmpty(Auth.CachedJwt))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        try
        {
            patient = await SharedPatients.GetPatientAsync(PatientId);
            if (patient is null) return;
            trends = await SharedPatients.GetTrendsAsync(PatientId, days: 30);
        }
        catch { patient = null; }
        finally { loading = false; }
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Lang.LanguageChanged -= OnLangChanged;
}
